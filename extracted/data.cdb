				{
					"id": "SpaceWheatQuest",
					"requires": [],
					"title": "The Seed of Renewal",
					"goal": "Study the strange plant from ::target-raw::.",
					"values": {
						"target": "P_Cairn_RadioactiveSpaceWheat",
						"resource": "SpaceWheatCore",
						"item": "SpaceWheat_Seed",
						"item2": "P_ThermoSuit",
						"count": 5,
						"reward": 500
					},
					"steps": [
						{
							"text": "Talk to ::npc:: on ::target::",
							"target": {
								"object": "Station_Cairn"
							},
							"props": {
								"npc": "LaboratoryStation_npc_LittleDoctor"
							}
						},
						{
							"text": "Open the character screen with [key.MenuCharacter] and equip a ::item2::.",
							"cond": "hasEvent(Event.GetRadSuit)",
							"target": {
								"hide": true
							},
							"props": {}
						},
						{
							"text": "Go to ::target::.",
							"props": {},
							"target": {
								"planet": "P_Cairn_RadioactiveSpaceWheat"
							},
							"cond": "hasEvent(Event.GetRadSuit) && isEquipped(mission.item2)"
						},
						{
							"text": "Find a ::resource:: on ::target-raw::.",
							"cond": "hasEvent(Event.GetRadSuit) && isEquipped(mission.item2) && getSystem() == mission.target.system",
							"props": {},
							"target": {
								"planet": "P_Cairn_RadioactiveSpaceWheat"
							}
						},
						{
							"text": "Land in a ::resource::.",
							"cond": "hasEvent(Event.GetRadSuit) && isEquipped(mission.item2) && planet == mission.target && radarHasResourcePinned(mission.resource)",
							"props": {}
						},
						{
							"text": "Press [key.Descend] over a flat surface to descend until you land.",
							"props": {},
							"group": 2,
							"cond": "!hasEvent(Event.GetSample) && isInShip() && hasEvent(Event.GetRadSuit) && isEquipped(mission.item2) && planet == mission.target && radarHasResourcePinned(mission.resource)"
						},
						{
							"text": "Find and gather ::count:: ::item:: by hand.",
							"cond": "hasEvent(Event.GetRadSuit) && isEquipped(mission.item2) && planet == mission.target && !isInShip()",
							"props": {
								"end": "GetSample"
							}
						},
						{
							"text": "Press [key.Ascend] to ascend.",
							"props": {},
							"group": 2,
							"cond": "hasEvent(Event.GetSample) && isInShip() && planet == mission.target && getGroundDistance()<150"
						},
						{
							"text": "Get a ::item:: in your inventory.",
							"cond": "hasEvent(Event.GetSample)",
							"props": {}
						},
						{
							"text": "Go back to ::target-raw::'s Laboratory.",
							"cond": "hasEvent(Event.GetSample) && hasItem(mission.item)",
							"target": {
								"object": "Station_Cairn"
							},
							"props": {}
						},
						{
							"text": "Study the ::item::.",
							"cond": "hasEvent(Event.GetSample) && hasItem(mission.item) && isInStation() && isInInstance(Instance.Laboratory)",
							"target": {
								"object": "Station_Cairn"
							},
							"props": {
								"end": "StudySample"
							}
						},
						{
							"text": "Share your results with ::npc::.",
							"cond": "hasEvent(Event.GetSample) && hasEvent(Event.StudySample)",
							"target": {
								"object": "Station_Cairn"
							},
							"props": {
								"npc": "LaboratoryStation_npc_LittleDoctor"
							}
						}
					],
					"event": [
						{
							"id": "GetRadSuit"
						},
						{
							"id": "GetSample"
						},
						{
							"id": "StudySample"
						}
					],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/SpaceWheatQuest.png"
					},
					"script": "function onStart(){\n\tprogress(getItemCount(mission.item));\n}\n\nfunction onGather(it,count){\n\tif (it == mission.item){\n\t\tprogress(count);\n\t\tif(isProgressFull()){\n\t\t\tsetEvent(Event.GetSample);\n\t\t\tif(getScienceLevel(mission.item)>0){\n\t\t\t\tsetEvent(Event.StudySample);\n\t\t\t}\n\t\t}\n\t\tdiscoverResource(Resource.SpaceWheatRoot);\n\t}\n}\n\nfunction onStudy(it,level){\n\tif (it == mission.item){\n\t\tsetEvent(Event.StudySample);\n\t}\n}",
					"guid": "#Ydg-v6I&-eRG",
					"category": "MissionScience"
				},
				{
					"id": "ScienceTuto2",
					"requires": [],
					"title": "Experimental Farmer",
					"goal": "Grow a plant from [SpaceWheat_Seed].",
					"values": {
						"phReward": "badge",
						"reward": 500
					},
					"steps": [
						{
							"text": "Build a [B_Farm] in one of your bases.",
							"props": {
								"end": "BuildFarm"
							}
						},
						{
							"text": "Grow any variant of [EinkornSeed] in your [B_Farm].",
							"props": {
								"end": "WheatCrafted"
							},
							"cond": "hasEvent(Event.BuildFarm)"
						},
						{
							"text": "Bring your findings to ::npc::.",
							"props": {
								"npc": "LaboratoryStation_npc_LittleDoctor"
							},
							"cond": "hasEvent(Event.WheatCrafted)"
						}
					],
					"event": [
						{
							"id": "BuildFarm"
						},
						{
							"id": "WheatCrafted"
						}
					],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/Farmer.png"
					},
					"script": "function onCheck(){\n\tif(getLocalBase()!= null && getLocalBase().hasBuilding(Item.B_Farm)){\n\t\ttriggerEvent(Event.BuildFarm);\n\t}\n}\n\nfunction onFarmGather(pl){\n\tif(pl ==Farm.ChillyEinkorn_Gather || pl == Farm.Plainkorn_Gather || pl == Farm.SourEinkorn_Gather ){\n\t\ttriggerEvent(Event.WheatCrafted);\n\t}\n}\n\nfunction onStart(){\n\tstartMission(Mission.SpaceWheatQuest_2);\n}",
					"guid": "#Ydg-v6I4-0&S",
					"category": "MissionScience"
				},
				{
					"id": "SpaceWheatQuest_2",
					"requires": [],
					"title": "Spacekorn Completionist",
					"goal": "Grow all variants of [EinkornSeed].",
					"values": {
						"reward": 1000
					},
					"steps": [
						{
							"text": "Grow [Plainkorn].",
							"cond": "!hasEvent(Event.GrowPlain)",
							"group": 0,
							"props": {
								"end": "GrowPlain"
							}
						},
						{
							"text": "Grow [SourEinkorn].",
							"cond": "!hasEvent(Event.GrowSour)",
							"group": 1,
							"props": {
								"end": "GrowSour"
							}
						},
						{
							"text": "Grow [ChillyEinkorn].",
							"cond": "!hasEvent(Event.GrowFrost)",
							"group": 2,
							"props": {
								"end": "GrowFrost"
							}
						}
					],
					"event": [
						{
							"id": "GrowPlain"
						},
						{
							"id": "GrowSour"
						},
						{
							"id": "GrowFrost"
						}
					],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/Spacekorn.png"
					},
					"script": "function onStart() {\n\thide();\n}\n\nfunction onRelocate() {\n\tif(hasCompletedMission(Mission.ScienceTuto2)){\n\t\tshow();\n\t}\n}\n\nfunction onFarmGather(pl){\n\tif(pl ==Farm.ChillyEinkorn_Gather){\n\t\ttriggerEvent(Event.GrowFrost);\n\t\tcheckCompletion();\n\t}\n\tif(pl == Farm.Plainkorn_Gather){\n\t\ttriggerEvent(Event.GrowPlain);\n\t\tcheckCompletion();\n\t}\n\tif(pl == Farm.SourEinkorn_Gather){\n\t\ttriggerEvent(Event.GrowSour);\n\t\tcheckCompletion();\n\t}\n}\n\nfunction checkCompletion(){\n\tif((hasEvent(Event.GrowPlain))&&(hasEvent(Event.GrowSour))&&(hasEvent(Event.GrowFrost))){\n\t\tcomplete();\n\t}\n}",
					"guid": "#Ydg-v6I8-PPM",
					"category": "MissionScience"
				},
				{
					"id": "Bureau01",
					"requires": [],
					"title": "MB#01: Integration Protocol",
					"goal": "Gather ::count:: of the following items:",
					"values": {
						"count": 2,
						"vars": {
							"counts": [
								0,
								0,
								0,
								0
							],
							"max": [
								6,
								30,
								3
							]
						},
						"reward": 150
					},
					"steps": [
						{
							"text": "<bad>::counts[1]::/::max[1]::</bad> ::item.Carbon::.",
							"props": {
								"lookupItems": [
									{
										"item": "Carbon"
									}
								]
							},
							"group": 1
						},
						{
							"text": "<good>::counts[1]::/::max[1]::</good> ::item.Carbon::.",
							"props": {},
							"group": 1,
							"cond": "vars.counts[1] >= vars.max[1]"
						},
						{
							"text": "<bad>::counts[0]::/::max[0]::</bad> ::item.Sandstone::.",
							"props": {
								"lookupItems": [
									{
										"item": "Sandstone"
									}
								]
							},
							"group": 2
						},
						{
							"text": "<good>::counts[0]::/::max[0]::</good> ::item.Sandstone::.",
							"props": {},
							"group": 2,
							"cond": "vars.counts[0] >= vars.max[0]"
						},
						{
							"text": "<bad>::counts[2]::/::max[2]::</bad> ::item.Pyrite::.",
							"props": {
								"lookupItems": [
									{
										"item": "Pyrite"
									}
								]
							},
							"group": 3
