				{
					"id": "FirstScience",
					"guid": "#Yiw-n6a7-ODu",
					"requires": [],
					"title": "Crystallization",
					"goal": "Advance your *Science* knowledge.",
					"values": {
						"item": "Sandstone",
						"targetObj": "Station_Cairn",
						"reward": 10
					},
					"steps": [
						{
							"text": "Use the *Laboratory* equipment to analyze one of the available materials.\n<small>For example, ::item:: is a good case study.</small>",
							"props": {},
							"cond": ""
						},
						{
							"text": "Go to ::target::",
							"props": {},
							"cond": "!isInStation(getTarget())"
						},
						{
							"text": "Check the *Laboratory* section of your *Knowledge* [key.MenuKnowledges]",
							"props": {},
							"cond": "hasEvent(Event.Studied)"
						},
						{
							"text": "Analyze more materials to increase your science level.",
							"props": {},
							"cond": "hasEvent(Event.Studied) && hasEvent(Event.ScienceOpen)"
						}
					],
					"event": [
						{
							"id": "Studied"
						},
						{
							"id": "ScienceOpen"
						}
					],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/FirstScience.png"
					},
					"script": "function onStudy(it,level) {\n\tsetEvent(Event.Studied);\n}\n\nfunction onXP(k,v) {\n\tif( getPlayerLevel(Attribute.Science) >= 1 ) complete();\n}\n\nfunction onCheck() {\n\tif( hasEvent(Event.Studied) && !hasEvent(Event.ScienceOpen) && inWindow(\"Permits\",\"Science\") )\n\t\ttriggerEvent(Event.ScienceOpen);\n}",
					"category": "MissionScience"
				},
