					"name": "Mag-Plasma Consumption"
				},
				{
					"id": "FTOilConsumptionFactorOnVisitedPath",
					"props": {
						"flags": 4608,
						"desc": "This FTL Engine has been tweaked to consume less mag-plasma when jumping through a known path."
					},
					"name": "Mag-Plasma Cost On Known Paths"
