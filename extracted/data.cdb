					"guid": "#Ydg-v6J6-8V9"
				},
				{
					"id": "TestEditor",
					"guid": "#al7-43RF-Nzz",
					"requires": [],
					"title": "Test Editor",
					"goal": "Test editor step",
					"values": {
						"item": "FTLEngine1"
					},
					"steps": [
						{
							"text": "Go to Shipyard",
							"props": {},
							"cond": "!isInShipyard()",
							"group": 0
						},
						{
							"text": "Use Ship Editor",
							"props": {},
							"cond": "isInShipyard() && !isInShipEditor()\n",
							"group": 1
						},
						{
							"text": "Equip ::item::",
							"props": {
								"showInShipEditor": true
							},
							"group": 2,
							"cond": "isInShipEditor() && !shipEditorItemEquipped(mission.item);"
						},
						{
							"text": "Well done!",
							"props": {
								"showInShipEditor": true
							},
							"cond": "isInShipEditor() && shipEditorItemEquipped(mission.item);\n",
							"group": 3
						}
					],
					"event": [],
					"intercom": [],
					"props": {},
					"script": ""
				}
			],
