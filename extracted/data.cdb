					},
					"script": "function onEvent(ev){\n\tif (ev == Event.GetArtefact)\n\t\tdiscoverItem(Item.QuestFakeAlienArtefact,false);\n\treturn true;\n}\n\nfunction onDrop(it,count){\n\tif (it == mission.item && count >0){\n\t\tfail();\n\t}\n}",
					"event": [
						{
							"id": "GetArtefact"
						},
