							"cond": "hasCompletedMission(Mission.Bureau01)"
						},
						{
							"text": "Talk to ::npc.MiningBureau_npc::, at the Mining Bureau to buy the coordinates of a specific item.",
							"props": {
								"subGoal": true,
								"npc": "MiningBureau_npc",
