						}
					],
					"title": "MK#04: Trade 1M",
					"goal": "Become a *quadrant-renowned* seller by trading a total of <price>1M</price> through the Trade Nexus.",
					"values": {
						"count": 1000000,
						"rewardNXT": 500
					},
					"steps": [
						{
							"text": "Traded <price>::count::</price>",
							"props": {}
						}
					],
					"event": [],
					"intercom": [],
					"props": {
						"flags": 1,
						"screenshot": "ui/mission_pictures/MerchantCorpo01.png"
					},
					"script": "function onStart() {\n\tsetProgress(getTotalMarketTrade() / mission.count);\n}\nfunction onSpecialAction(act) {\n\tif( act == SpecialAction.MarketTrade ) {\n\t\tsetProgress(getTotalMarketTrade() / mission.count);\n\t\tif( isProgressFull() ) complete();\n\t}\n}",
					"guid": "#Ydg-v6Iu-8eV",
					"category": "MissionProgress"
				},
				{
					"id": "MerchantCorpo02",
					"guid": "#ZR6-hshi-M7P",
					"requires": [
						{
							"mission": "MerchantCorpo01"
						}
					],
					"title": "MK#05: Trade 10M",
					"goal": "Become a *galactically renowned* seller by trading a total of <price>10M</price> through the Trade Nexus.",
					"values": {
						"count": 10000000,
						"rewardNXT": 500
					},
					"steps": [
						{
							"text": "Traded <price>::count::</price>",
							"props": {}
						}
					],
					"event": [],
					"intercom": [],
					"props": {
						"flags": 1,
						"screenshot": "ui/mission_pictures/MerchantCorpo01.png"
					},
					"script": "function onStart() {\n\tsetProgress(getTotalMarketTrade() / mission.count);\n}\nfunction onSpecialAction(act) {\n\tif( act == SpecialAction.MarketTrade ) {\n\t\tsetProgress(getTotalMarketTrade() / mission.count);\n\t\tif( isProgressFull() ) complete();\n\t}\n}",
					"category": "MissionProgress"
				},
				{
					"id": "ShipWreck",
					"requires": [],
					"title": "Gathering wreckage",
					"goal": "Detect and gather the debris",
					"values": {
						"resource": "ShipWreck_Core",
						"count": 3,
						"reward": 10
					},
					"steps": [
						{
							"text": "Detect debris on a planet",
							"props": {}
						},
						{
							"text": "Approach the ::resource:: wreckage",
							"props": {},
							"cond": "radarHasDetectedResource(Resource.ShipWreck_Core)"
						},
						{
							"text": "Land close to the ::resource:: wreckage\n<small>Use [key.Descend] to land your ship on a flat area</small>",
							"props": {},
							"cond": "radarHasResourcePinned(Resource.ShipWreck_Core)\n"
						},
						{
							"text": "Gather ::count:: debris nearby",
							"props": {},
							"cond": "!isInShip() && planet != null && planet.hasResourceInDistance(Resource.ShipWreck_Core,100)"
						}
					],
					"event": [],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/ShipWreck.png"
					},
					"script": "function onGather(it,count) {\n\tif( !isInShip() && planet != null && planet.hasResourceInDistance(Resource.ShipWreck_Core,100)) {\n\t\tprogress(count);\n\t\tif( isProgressFull() ){\n\t\t\tdiscoverResource(Resource.ShipWreck_Encyclopedia);\n\t\t\tcomplete();\n\t\t}\n\t}\n}",
					"guid": "#Ydg-v6J3-1Ky",
					"category": "MissionExploration"
				},
				{
					"id": "ReachHorizonStation",
					"requires": [],
					"title": "New Horizons",
					"goal": "Find the station in ::target-sector::.",
					"values": {
						"targetObj": "Station_Horizon"
					},
					"steps": [
						{
							"text": "Go to ::target::.",
							"props": {}
						},
						{
							"text": "Dock on ::target:: station.",
							"props": {
								"showCompleted": true
							},
							"cond": "getSystem() == mission.target.system"
						}
					],
					"event": [],
					"intercom": [],
					"props": {
						"flags": 4,
						"screenshot": "ui/mission_pictures/ReachHorizonStation.png"
					},
					"script": "function onRelocate() {\n\tif(isInStation() && getSystem() == mission.target.system){\n\t\tcomplete();\n\t}\n}",
					"guid": "#Ydg-v6JH-WzN",
					"category": "MissionExploration"
				},
				{
					"id": "PlanetHeat",
					"guid": "#bN&-R6ek-CeN",
					"requires": [
						{
							"mission": "ScienceLv2"
						},
						{
							"mission": "Bureau04"
						},
						{
							"mission": "Deprecated"
						}
					],
					"title": "Temperature Management",
					"goal": "Explore a <img src=\"icon/HotPlanet\"/>*hot planet* and mine ::count:: ::resource::",
					"values": {
						"count": 10,
						"resource": "IronTitaneCluster_Titanomagnetite",
						"item": "Radiator",
						"reward": 500
					},
					"steps": [
						{
							"text": "Explore the planet and mine its resources.\n<small>Thanks to the ::item::, the heat should be managable</small>",
							"props": {}
						},
						{
							"text": "Obtain ::resource:: location from ::target:: Mining Bureau",
							"props": {},
							"target": {
								"object": "Station_Cairn"
							},
							"cond": "!isResourceScanned(mission.resource) && !hasBeacon(mission.resource,true)"
						},
						{
							"text": "Craft and install ::item:: on your ship",
							"props": {},
							"cond": "!getShip()?.hasComponent(mission.item)"
						}
					],
					"event": [],
					"intercom": [],
					"props": {
						"flags": 16,
						"screenshot": "ui/mission_pictures/PlanetHeat.png"
					},
					"script": "function onGather(_,_) {\n\tif( getGatheredResource() == mission.resource ) {\n\t\tprogress(1);\n\t\tif( isProgressFull() ) complete();\n\t}\n}",
					"category": "MissionExploration"
				},
				{
					"id": "Test",
					"requires": [],
					"title": "Test Mission",
					"goal": "Test the mission system",
					"values": {
						"target": "Start1"
					},
					"steps": [
						{
							"text": "Go to ::target-raw::",
							"target": {
								"instance": "TestInstance"
							},
							"props": {
								"end": "testEvent"
							},
							"cond": ""
						},
						{
							"text": "Do something else",
							"props": {},
							"cond": "hasEvent(Event.testEvent)"
						}
					],
					"event": [
