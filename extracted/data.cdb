				},
				{
					"id": "Battery",
					"props": {},
					"icon": {
						"file": "ui/windows/hd_sprite-sheet_ic.png",
						"size": 32,
						"x": 1,
						"y": 0
					},
					"text": "Battery",
					"desc": "The ship’s battery is drained by various <res>modules, weapons and systems</res>, and replenished by the ship’s <res>generators</res>."
				},
				{
					"id": "Hull",
					"props": {},
					"icon": {
						"file": "ui/windows/hd_sprite-sheet_ic.png",
						"size": 32,
						"x": 2,
						"y": 0
					},
					"desc": "The ship’s hull provides resistance against various forms of damage. Pilot your ship carefully, or you'll be in for a full repaint!",
					"text": "Hull"
				},
				{
					"id": "Credits",
					"props": {},
