				{
					"id": "Storage",
					"props": {},
					"icon": {
						"file": "ui/icons/icon_interface_fichier_export_vecto.png",
						"size": 24,
						"x": 11,
						"y": 0
					},
					"text": "Storage",
					"desc": "Storage Units (su) represent your ship’s capacity to carry materials in various forms. When maximum storage is exceeded, your ship will be slowed down until you dispose of some cargo."
				},
				{
					"id": "Health",
					"props": {},
					"icon": {
						"file": "ui/icons/Health.png",
						"size": 32,
						"x": 0,
						"y": 0
					},
					"text": "Health",
					"desc": "It's impossible to meaningfully evaluate a person’s overall well-being with a single criterion. Health is a complex balance of physical and psychological factors in fragile equilibrium. Even so, The Company helpfully provides a simple numeric approximation to empower contractors to manage their own health as they see fit."
				},
				{
					"id": "Temperature",
					"props": {},
					"icon": {
						"file": "ui/icons/actionIcons.png",
						"size": 24,
						"x": 1,
						"y": 5
					},
					"text": "Temperature",
					"desc": "Extreme temperature can cause injury surprisingly fast. Contractors are encouraged to dress appropriately for each landing site to reduce the risks of frostbite, hypothermia, heatstroke, exhaustion and/or death."
				},
				{
					"id": "TemperatureNormal",
					"props": {},
