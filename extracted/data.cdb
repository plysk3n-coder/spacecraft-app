					"name": "Equip Cost",
					"props": {
						"flags": 2,
						"desc": "The Equip Cost of contractor equipment limits how much a single contractor can hold at once."
					},
					"unit": "pts"
				},
				{
					"id": "ItemDurability",
					"props": {
						"flags": 2,
						"desc": "Nothing is eternal. This item slowly degrades every time it is used, until it eventually no longer functions."
					},
					"name": "Durability",
					"unit": ""
				},
				{
					"id": "Temperature",
					"props": {
						"flags": 2,
						"desc": "The ship’s current average Temperature is a function of how much heat the ship stores compared to its Heat Capacity. If the Temperature gets too high or too low, the ship will be damaged."
					},
					"name": "Temperature",
					"unit": "°C"
				},
				{
					"id": "HeatProtection",
					"props": {
						"desc": "Heat Protection improves the suit’s ability to shield a contractor from high temperatures."
					},
					"name": "Heat Protection"
				},
				{
					"id": "ColdProtection",
					"props": {
						"desc": "Cold Protection improves the suit’s ability to shield a contractor from freezing temperatures."
					},
					"name": "Cold Protection"
				},
				{
					"id": "Radioactivity",
					"props": {},
					"name": "Radioactivity",
					"unit": "MBq"
				},
				{
					"id": "RadioactivityProtection",
					"props": {
						"desc": "Radioactivity Protection shields the contractor from all harmful radiation, up to a certain range."
					},
					"name": "Radioactivity Protection",
					"unit": "MBq",
					"note": "How much radiation is absorbed by the item"
				},
				{
					"id": "BeaconRange",
					"props": {
						"desc": "The amount of resources in range of the beacon will be incorporated into its quantum signature."
					},
					"name": "Range",
					"unit": "m"
				},
				{
					"id": "MaxTechXP",
					"props": {
						"flags": 2,
						"desc": "Experience in the Technology branch is acquired by building new bases and crafting components in automated factories.\n\nEach base has a maximum amount of Technology Experience that can be acquired in this way."
					},
					"note": "",
					"name": "Experience Capacity"
				},
				{
					"id": "PatchSlots",
					"props": {
						"flags": 2,
						"desc": "This item can receive patches to improve its performance. Equipped patches cannot be removed without destroying the whole item."
					},
					"name": "Patch Slots",
					"note": "How many patches an item can have"
				},
				{
					"id": "ShuttleSlots",
					"props": {},
					"name": "Shuttle Slots",
					"note": "How many slots a shuttle pad can have"
				},
				{
					"id": "ShuttleRange",
					"props": {
						"desc": "How far the shuttle can travel."
					},
					"name": "Shuttle Range",
					"unit": "np"
				},
				{
					"id": "Frame",
					"name": "Frame",
					"props": {
						"flags": 2,
						"desc": "Frame corresponds to a ship’s structural capacity to not break apart under its own Weight. It increases the ship’s Integrity."
					}
				},
				{
					"id": "ShipWeight",
					"name": "Weight",
					"unit": "t",
					"props": {
						"flags": 128,
						"desc": "Weight is a measure of the ship’s total mass. It impacts its structural Integrity, as well as its ability to move."
					},
					"note": "Used for ship parts and tools, to determine the total weight of the ship"
				},
				{
					"id": "Hull",
					"name": "Hull",
					"props": {
						"flags": 2,
						"desc": "Hull represents your ship’s overall resistance. When a ship is out of Hull points, it is out of order and requires towing."
					}
				},
				{
					"id": "CurrentHull_Display",
					"props": {
						"flags": 2
					},
					"name": "Current Hull"
				},
				{
					"id": "HeatCapacity",
					"name": "Heat Capacity",
					"unit": "MJ/K",
					"props": {
						"flags": 2,
						"desc": "Heat Capacity corresponds to the amount of energy needed to raise the ship’s temperature. The bigger the ship, the higher its Heat Capacity, and the more heat it can absorb before overheating."
					}
				},
				{
					"id": "HeatInterfaceMaterial",
					"props": {
						"desc": "A material’s Heat Conductivity determines how fast heat can move through it. A hull made of highly Heat Conductive materials will have a greater Heat Interface, and will change Temperature faster depending on the environment."
					},
					"name": "Material Heat Conductivity",
					"unit": "W/aK"
				},
				{
					"id": "HeatInterfaceParts",
					"name": "Parts Heat Interface",
					"unit": "(kW/K)^(3/2)",
					"props": {
						"flags": 1
					},
					"note": "Heat Interface Parts of any hull piece is supposed to be HeatInterfaceMaterial * Ship Part Size. The fact that the ship part size is not an actual attribute does not change that. Comparing material of part of the same size should give you an idea of how it will affect the heat interface. Because of that, heat interface cannot really be compute from any other stat and must be given by hand, but it must still be informally based on HeatInterfaceMaterial and the part size."
				},
				{
					"id": "HeatInterfaceShip",
					"name": "Heat Interface",
					"props": {
						"flags": 2,
						"desc": "Heat Interface corresponds to the amount of heat transfer between the ship and its environment. It changes with the size of the ship, but also with the materials used in its construction. The greater the Heat Interface, the faster the ship will be affected by environmental temperatures."
					},
					"unit": "MW/K"
				},
				{
					"id": "SystemSupport",
					"name": "System Support",
					"unit": "SP",
					"props": {
						"flags": 2,
						"desc": "System Support is the number of secondary systems available in your ship to service its modules. If System Requirements become greater than System Support, the ship will have a harder time evacuating heat properly from its module, leading to faster overheating."
					}
				},
				{
					"id": "SystemRequirement",
					"name": "System Requirements",
					"unit": "SP",
					"props": {
						"flags": 130,
						"desc": "System Requirements represent how much help a module needs from secondary systems to function properly without overheating."
					}
				},
				{
					"id": "SystemMalusForShipPoints",
					"props": {
						"flags": 1
					},
					"name": "System Penalty",
					"unit": "SP"
				},
				{
					"id": "SystemEfficiency",
					"props": {
						"flags": 4098,
						"displayScale": 100,
						"desc": "System Efficiency represents the extent to which the ship's system support is sufficient to meet its requirements.\n\nSystem Efficiency will affect various systems such as Heat or Engine."
					},
					"name": "System Efficiency"
				},
				{
					"id": "EngineForce",
					"name": "Force",
					"unit": "t",
					"props": {
						"shipName": "Engine Force",
						"desc": "An engine’s Force determines how much weight can be moved by the engine. If the total force of all of a ship’s engines is less than its total weight, the ship will not be able to move."
					}
				},
				{
					"id": "EngineThrust",
					"name": "Thrust",
					"unit": "np/s",
					"props": {
						"shipName": "Engine Thrust",
						"desc": "The Thrust of an engine determines how fast it can move and accelerate. Multiple engines produce less thrust than the sum of their individual thrusts, and heavy ships move slower than lighter ones."
					}
				},
				{
					"id": "EngineThrustBonusUpwards",
					"props": {
						"flags": 4100,
						"displayScale": 100,
						"desc": "An engine optimized for going up will make the ship move faster when attempting to leave orbit."
					},
					"name": "Liftoff Speed Bonus"
				},
				{
					"id": "FTOilStorage",
					"name": "Mag-Plasma Storage",
					"unit": "L",
					"props": {
						"desc": "This item can hold mag-plasma, the physics-defying material allowing for safe supraluminal travel."
					}
				},
				{
					"id": "FTLEngineJumpCost",
					"name": "FTL Jump Cost",
					"unit": "L/np",
					"props": {
						"desc": "The jump cost of an FTL engine determines the base cost of a FTL jump, without taking the ship’s Weight into account.",
						"flags": 1
					}
				},
				{
					"id": "FTLEngineWeightCapacity",
					"name": "FTL Weight Capacity",
					"unit": "t",
					"props": {
						"desc": "An FTL engine’s weight capacity determines how much the ship’s weight impacts the cost of a FTL jump. The greater the weight capacity, the less the weight of the ship will matter.",
						"flags": 1
					}
				},
				{
					"id": "FakeFTLEngineClass",
					"props": {
						"desc": "More performant FTL engines do the same route with less mag-plasma, but they require a greater expertise.",
						"flags": 2
					},
					"name": "FTL Engine Class"
				},
				{
					"id": "FakeFTLOptimalMaxWeight",
					"props": {
						"desc": "Each FTL engine is calibrated for transporting a certain mass of matter. Using the wrong engine for your ship will cause an overconsumption of mag-plasma, leading to a potential increase of supraluminic damage."
					},
					"name": "Optimal up to",
					"unit": "t"
				},
				{
					"id": "FTOilConsumptionFactor",
					"props": {
						"flags": 4608,
						"desc": "This FTL Engine has been tweaked to consume less mag-plasma per jump."
