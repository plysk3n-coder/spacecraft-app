				},
				{
					"id": "Exploration",
					"name": "Exploration",
					"unit": "",
					"props": {
						"desc": "Exploration is the art of traveling to unknown places, going farther than anyone else before, and pushing the frontiers of human settlement in the galaxy.\nComplete *planet resource discovery* to increase your Exploration XP.",
						"flags": 2
					},
					"icon": {
						"file": "ui/icons/export_icon_filiale.png",
						"size": 128,
						"x": 0,
						"y": 0
					}
				},
				{
					"id": "Technology",
					"name": "Technology",
					"unit": "",
					"props": {
						"desc": "Technology is all about improving industrial output to build more, better, and faster.\nEarn *Technology XP* in your space base’s command center by producing components through automation. You also get extra *XP* when deploying a new base building for the first time.",
						"flags": 2
					},
					"icon": {
						"file": "ui/icons/export_icon_filiale.png",
						"size": 128,
						"x": 1,
						"y": 0
					}
				},
				{
					"id": "Science",
					"name": "Science",
					"props": {
						"desc": "Understanding the mysteries of the universe won’t always lead to immediate benefits, but it's the only way forward for humanity, and for the Company Science program.\nStudy minerals and organic resources at the *Laboratory* to increase your science XP.",
						"flags": 2
					},
					"icon": {
						"file": "ui/icons/export_icon_filiale.png",
						"size": 128,
						"x": 3,
						"y": 0
					}
				},
				{
					"id": "Social",
					"name": "Social",
					"props": {
						"desc": "The Galaxy is a global competition between Corpos. Your Social level represents your personal achievements accumulated over time.\nEarn social XP by joining a Corpo, then complete *Corpo Requests* to increase your social XP.",
						"flags": 2
					},
					"icon": {
						"file": "ui/icons/PathTechnologyIcon.png",
						"size": 128,
						"x": 0,
						"y": 0
					}
				},
				{
					"id": "Combat",
					"name": "Combat",
					"props": {
						"desc": "Combat will allow you to fight in PvE and coop against Space Pirate foes. It will be real-time, but will not require intense action.\n*Combat is not part of the initial Early Access release*, but we are working on it and will keep you posted!",
						"flags": 2
					},
					"icon": {
						"file": "ui/icons/export_icon_filiale.png",
