							"id": "Beacon"
						}
					],
					"intercom": [
						{
							"id": "End",
							"text": "Good. Now that you've seen what the Bureau can do for you, it's time you did something for the Bureau. We're looking for geological information on various planets. Please explore these planets and send us the data you collect.",
							"props": {
								"portrait": "MiningBureau_npc"
							}
						}
					],
					"props": {
						"flags": 8,
						"screenshot": "ui/mission_pictures/Integration Protocol.png"
					},
					"script": "var items = [Item.Sandstone,Item.Carbon,Item.Pyrite];\nfunction onGather(it,count) {\n\tfor(i => it2 in items)\n\t\tif( it == it2 && vars.counts[i] < vars.max[i] ) {\n\t\t\tvars.counts[i] += count;\n\t\t\tif( vars.counts[i] >= vars.max[i] ) {\n\t\t\t\tvars.counts[i] = vars.max[i];\n\t\t\t\tprogress(1);\n\t\t\t\tif( mission.currentCount >= mission.count ) {\n\t\t\t\t\tcomplete();\n\t\t\t\t\treturn;\n\t\t\t\t}\n\t\t\t}\n\t\t}\n}\nfunction onCheck() {\n\tif( hasBeacon() ) triggerEvent(Event.Beacon);\n}",
					"guid": "#Ydg-v6IC-euu",
					"category": "MissionBureau"
				},
				{
					"id": "Bureau02",
					"requires": [
						{
							"mission": "Bureau01"
						}
					],
					"title": "MB#02: Full Survey",
					"goal": "Explore ::count:: of the following planets.",
					"values": {
						"count": 2,
						"reward": 150
					},
					"steps": [
						{
							"text": "::target-raw:: <bad>not explored</bad>",
							"props": {},
							"group": 0,
							"cond": ""
						},
						{
							"text": "::target-raw:: <good>explored</good>",
							"props": {
								"ignoreTarget": true
							},
							"group": 0,
							"cond": "hasEvent(Event.Planet0)"
						},
						{
							"text": "::target-raw:: <bad>not explored</bad>",
							"props": {},
							"group": 1
						},
						{
							"text": "::target-raw:: <good>explored</good>",
							"props": {
								"ignoreTarget": true
							},
							"group": 1,
							"cond": "hasEvent(Event.Planet1)"
						},
						{
							"text": "::target-raw:: <bad>not explored</bad>",
							"props": {},
							"group": 2
						},
						{
							"text": "::target-raw:: <good>explored</good>",
							"props": {
								"ignoreTarget": true
							},
							"group": 2,
							"cond": "hasEvent(Event.Planet2)"
						},
						{
							"text": "Two planets were explored",
							"props": {
								"showCompleted": true
							},
							"cond": "false"
						}
					],
					"event": [
						{
							"id": "Planet0"
						},
						{
							"id": "Planet1"
						},
						{
							"id": "Planet2"
						}
					],
					"intercom": [
						{
							"id": "End",
							"text": "All right! With your help, we were able to gather valuable geological information on these planets. Thanks!\nNow that the Bureau trusts you, it's time to get some work done. I’ve just recommended you to a colleague. Don't make me look bad!",
							"props": {
								"portrait": "MiningBureau_npc"
							}
						}
					],
					"props": {
						"screenshot": "ui/mission_pictures/Full Survey.png"
					},
					"script": "function onStart() {\n\tvar planets = [];\n\tvar systems = [];\n\tvar i = 0;\n\twhile( i < 3 ) {\n\t\tvar p = locatePlanetUnknown(70000, planets);\n\t\tif( p == null ) {\n\t\t\tsetEvent(switch( i ) {\n\t\t\tcase 0: Event.Planet0;\n\t\t\tcase 1: Event.Planet1;\n\t\t\tcase 2: Event.Planet2;\n\t\t\t});\n\t\t\tprogress(1);\n\t\t\ti++;\n\t\t\tcontinue;\n\t\t}\n\t\tplanets.push(p);\n\t\tvar sys = p.system;\n\t\tif( systems.indexOf(sys) >= 0 )\n\t\t\tcontinue;\n\t\tif( p.hasDarkResource() || p.getMaxResourceLevel() > 3 )\n\t\t\tcontinue;\n\t\tsystems.push(sys);\n\t\tif( sys.sector.getExplorationLevel() > 1 )\n\t\t\tcontinue;\n\t\tsetTarget(p,i++);\n\t}\n\tif( isProgressFull() ) complete();\n}\n\nfunction onDiscoverPlanet(p) {\n\tif( p.isExplored()){\n\t\tfor( i in 0...3 ) {\n\t\t\tif( p == getTarget(i) ) {\n\t\t\t\tvar ev = switch( i ) {\n\t\t\t\tcase 0: Event.Planet0;\n\t\t\t\tcase 1: Event.Planet1;\n\t\t\t\tcase 2: Event.Planet2;\n\t\t\t\t};\n\t\t\t\tif( !hasEvent(ev) ) {\n\t\t\t\t\tsetEvent(ev);\n\t\t\t\t\tprogress(1);\n\t\t\t\t\tif( isProgressFull() ) complete();\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n}",
					"guid": "#Ydg-v6IH-zZu",
					"category": "MissionBureau"
				},
				{
					"id": "BureauInstance01",
					"guid": "#bJ6-Cke0-r87",
					"requires": [
						{
							"mission": "Bureau02"
						}
					],
					"title": "MB#S1: Restricted Areas",
					"goal": "Explore ::count:: restricted areas.",
					"values": {
						"count": 2,
						"reward": 300
					},
					"steps": [
						{
							"text": "Discover and complete more Restricted Areas.\n<small>You can buy additional location at the Mining Bureau</small>",
							"props": {}
						},
						{
							"text": "Buy the location for one of the Restricted Areas.",
							"props": {},
							"cond": "!hasEvent(Event.Bought)"
						},
						{
							"text": "Go to the nearest *Mining Bureau*",
							"props": {},
							"cond": "!hasEvent(Event.Bought) && !isInInstance(Instance.MiningBureau)"
						}
					],
					"event": [
						{
							"id": "Bought"
						}
					],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/BureauInstance01.png"
					},
					"script": "function sync() {\n\tsetValue(getCompletedInstances());\n\tif( isProgressFull() ) complete();\n}\n\nfunction onStart() {\n\tsync();\n}\n\nfunction onCompleteInstance(_) {\n\tsync();\n}",
					"category": "MissionBureau"
				},
				{
					"id": "BureauInstance02",
					"guid": "#bJ6-Doe4-8AJ",
					"requires": [
						{
							"mission": "BureauInstance01"
						}
					],
					"title": "MB#S2: Salvaging the Unknown",
					"goal": "Explore ::count:: restricted areas.",
					"values": {
						"count": 6,
						"reward": 500
					},
					"steps": [
						{
							"text": "Discover and complete more Restricted Areas.\n<small>You can buy additional location at the Mining Bureau</small>",
							"props": {}
						}
					],
					"event": [],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/BureauInstance01.png"
					},
					"script": "function sync() {\n\tsetValue(getCompletedInstances());\n\tif( isProgressFull() ) complete();\n}\n\nfunction onStart() {\n\tsync();\n}\n\nfunction onCompleteInstance(_) {\n\tsync();\n}",
					"category": "MissionBureau"
				},
				{
					"id": "Bureau03",
					"guid": "#bJ5-r2dy-VBV",
					"requires": [
						{
							"mission": "Bureau02"
						}
					],
					"title": "MB#03: Boom Boom Boom!",
					"goal": "Learn the art of beautiful (and controlled) explosions",
					"values": {
						"permit": "P_Explosives",
						"item": "BlastMissile0",
						"item2": "ExplodingToolMk1",
						"reward": 400
					},
					"steps": [
						{
							"text": "Your ship is now ready to blast some *Shell Resource*. Fire your ::item:: at them!",
							"props": {}
						},
						{
							"text": "Craft ::item:: and assign it as your skill ammunition.\n<small>You can assign ammunition on your skill in the ship menu [key.MenuShip]</small>",
							"props": {},
							"cond": "getShip()?.getSkillAttachment(Skill.MiningMissile) != mission.item"
						},
						{
							"text": "Craft ::item2:: and equip it on your ship",
							"props": {},
							"cond": "!getShip()?.hasSkill(Skill.MiningMissile)"
						},
						{
							"text": "Unlock the ::permit:: permit.",
							"props": {},
							"cond": "!hasPermit(mission.permit)"
						}
					],
					"event": [],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/Bureau03.png"
					},
					"script": "function onGather(_,_) {\n\tvar res = getGatheredResource();\n\tif( isResourceShell(res) ) {\n\t\tcomplete();\n\t\tsetMissionVar(Mission.MoreShells,\"res\",[res]);\n\t\tdispatchMissionEvent(Mission.MoreShells, \"Check\");\n\t}\n}",
					"category": "MissionBureau"
				},
				{
					"id": "MoreShells",
					"guid": "#bLc-PsOv-hGp",
					"requires": [
						{
							"mission": "Bureau03"
						}
					],
					"title": "MB#S3: More Shells",
					"goal": "Explode ::count:: different shells.",
					"values": {
						"count": 4,
						"vars": {
							"res": []
						},
						"reward": 500
					},
					"steps": [
						{
							"text": "[::vars.res[0]::] <good>exploded</good>",
							"props": {},
							"group": 0,
							"cond": "vars.res.length >= 1"
						},
						{
							"text": "[::vars.res[1]::] <good>exploded</good>",
							"props": {},
							"group": 1,
							"cond": "vars.res.length >= 2"
						},
						{
							"text": "[::vars.res[2]::] <good>exploded</good>",
							"props": {},
							"group": 2,
							"cond": "vars.res.length >= 3"
						}
					],
					"event": [
						{
							"id": "Check"
						}
					],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/MoreShells.png"
					},
					"script": "function onEvent(ev) {\n\tsetValue(vars.res.length);\n\treturn true;\n}\n\nfunction onGather(_,_) {\n\tvar r = getGatheredResource();\n\tif( isResourceShell(r) && vars.res.indexOf(r) < 0 ) {\n\t\tvars.res.push(r);\n\t\tvars.res = vars.res; // update\n\t\tsetValue(vars.res.length);\n\t\tif( isProgressFull() ) complete();\n\t}\n}",
					"category": "MissionBureau"
				},
				{
					"id": "Bureau04",
					"requires": [
						{
							"mission": "Bureau03"
						}
					],
					"title": "MB#04: Deposit Location",
					"goal": "Create a ::item:: and gather information about a deposit",
					"values": {
						"item": "Beacon",
						"reward": 500
					},
					"steps": [
						{
							"text": "Locate an [IronDeposit] or [CopperDeposit] on a planet.\n<small>You can visit the *Mining Bureau* to locate an available deposit.</small>",
							"props": {},
							"cond": ""
						},
						{
							"text": "Approach the detected deposit and scan it",
							"props": {},
							"cond": "radarHasDetectedResource(Resource.IronDeposit) || radarHasResourceAtRange(Resource.IronDeposit) ||\nradarHasDetectedResource(Resource.CopperDeposit) || radarHasResourceAtRange(Resource.CopperDeposit)"
						},
						{
							"text": "Press [key.Descend] over a flat surface to descend until you land close to the deposit",
							"props": {},
							"cond": "(radarHasResourceAtRange(Resource.IronDeposit) && isResourceScanned(Resource.IronDeposit)) ||\n(radarHasResourceAtRange(Resource.CopperDeposit) && isResourceScanned(Resource.CopperDeposit))"
						},
						{
							"text": "No deposit was found nearby. Take off and find another location.",
							"props": {},
							"cond": "isOnPlanet()"
						},
						{
							"text": "Deploy the ::item:: using [key.DeployBeacon]",
							"props": {},
							"cond": "isOnPlanet() && (locateNearestResource(Resource.IronDeposit,150) != null || locateNearestResource(Resource.CopperDeposit,150) != null)"
						},
						{
							"text": "Equip the ::item:: using [key.MenuCharacter]",
							"props": {},
							"cond": "!isEquipped(mission.item)"
						},
						{
							"text": "Craft a ::item::",
							"props": {},
							"cond": "!hasItem(mission.item)"
						},
						{
							"text": "Gather ::inventory.CalcifiedInvariant.4:: and study them at the *Laboratory*\n<small>Use your Encyclopedia [key.MenuEncyclopedia] to find the matching resource</small>",
							"props": {},
							"cond": "!canCraft(mission.item)"
						},
						{
							"text": "Take the [BeaconKey] linked to the beacon back to the nearest *Mining Bureau*",
							"props": {},
							"cond": "hasEvent(Event.deploy) && (hasBeacon(Resource.IronDeposit) || hasBeacon(Resource.CopperDeposit))"
						}
					],
					"event": [
						{
							"id": "deploy"
						},
						{
							"id": "give"
						}
					],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/DepositLocation.png"
					},
					"script": "function onDeploy(b) {\n\tif( b == Item.Beacon && (hasBeacon(Resource.IronDeposit) || hasBeacon(Resource.CopperDeposit)) )\n\t\tsetEvent(Event.deploy);\n}\n\nfunction onEvent(g) {\n\tif( g == Event.give ) {\n\t\tif( !consumeBeacon(Resource.IronDeposit) ) consumeBeacon(Resource.CopperDeposit);\n\t\tcomplete();\n\t}\n\treturn true;\n}",
					"guid": "#Ydg-v6IK-RRp",
					"category": "MissionBureau"
				},
