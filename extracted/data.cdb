							"props": {}
						},
						{
							"text": "Dock on ::target::.",
							"cond": "hasItem(Item.QuestFakeAlienArtefact) && getSystem() == mission.target.system",
							"props": {}
						},
						{
							"text": "Take the elevator to the *Laboratory*.",
							"cond": "hasItem(Item.QuestFakeAlienArtefact) && isInStation() && (getSystem() == mission.target.system)",
							"props": {}
						},
						{
							"text": "Show the ::item:: to the laboratory clerk.",
							"cond": "hasItem(Item.QuestFakeAlienArtefact) && isInInstance(Instance.Laboratory) && isInStation() && (getSystem() == mission.target.system)",
							"props": {}
						},
						{
							"text": "Study the ::item:: in the laboratory.",
							"cond": "hasItem(Item.QuestFakeAlienArtefact) && isInInstance(Instance.Laboratory) && isInStation() && (getSystem() == mission.target.system) && hasEvent(Event.TalkToClerk)",
							"props": {}
