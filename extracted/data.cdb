		{
			"name": "resGroup@props",
			"props": {
				"hide": true,
				"isProps": true
			},
			"separators": [],
			"lines": [],
			"columns": [
				{
					"typeStr": "4",
					"name": "explodingChance",
					"opt": true,
					"display": 1
				},
				{
					"typeStr": "4",
					"name": "groupDensity",
					"opt": true,
					"documentation": "This is actually the opposite of a density : the higher it is, the more space there is to spawn each resource"
				},
				{
					"typeStr": "2",
					"name": "flatTerrain",
					"opt": true,
					"documentation": "If set for a root group :\n- will try to find a flat area\n- for each of its children (groups and resources) :\n    - when child is flatTerrain -> will also try to find a flat area\n    - otherwise, will not check terrain at all\nIf not set (or set to false) for a root group :\n- will try to find a steep area\n- for each of its children (groups and resources) :\n    - will not check for terrain at all (even if flatTerrain is set)"
				},
				{
					"typeStr": "4",
					"name": "size",
					"opt": true
				}
			]
		},
