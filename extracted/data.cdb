			"lines": [
				{
					"id": "TutoIntercomMission",
					"requires": [],
					"title": "Tutorial Intercom Mission",
					"goal": "",
					"values": {
						"vars": {
							"quartzSold": 0
						}
					},
					"steps": [],
					"event": [
						{
							"id": "FirstWildSector"
						},
						{
							"id": "FirstLaserLost"
						},
						{
							"id": "FirstRadarLost"
						},
						{
							"id": "FirstSectorSellQuartz"
						}
					],
					"intercom": [
						{
							"id": "FirstWildSector",
							"text": "Right now, you’re in the middle of nowhere. You’ll find no space station in this sector, and none of *The Company*’s services. It’s just you in the infinite void.\nThat means you’ll have to survive by yourself. Which is part of the job. The best way to find interesting stuff is to visit unexplored or deserted sectors like this one.",
							"props": {
								"portrait": "TutoNPC"
							}
						}
					],
					"props": {
						"flags": 38
					},
					"script": "function onStart() {\n\thide();\n}\n\nfunction onFTL(origin,target) {\n\tif( !hasEvent(Event.FirstWildSector) && target.sector.getExplorationLevel()>1 && !isChangingServer() ) {\n\t\ttriggerEvent(Event.FirstWildSector);\n\t\tplayIntercom(Intercom.FirstWildSector);\n\t}\n\tif(hasEvent(Event.FirstSectorSellQuartz)){\n\t\tunsetEvent(Event.FirstSectorSellQuartz);\n\t}\n}\n\nfunction onTrade(it,count) {\n\tif(count >0){ // I sell count items\n\t\tif(it == Item.MiningTool0){\n\t\t\ttriggerEvent(Event.FirstLaserLost);\n\t\t}\n\t\tif(it == Item.Radar0){\n\t\t\ttriggerEvent(Event.FirstRadarLost);\n\t\t}\n\t}\n\tif(it == Item.Quartz && !hasCompletedMission(Mission.CraftFTL)){\n\t\tvars.quartzSold += count;\n\t\tif (vars.quartzSold >=5){\n\t\t\ttriggerEvent(Event.FirstSectorSellQuartz);\n\t\t}\n\t\telse{\n\t\t\tunsetEvent(Event.FirstSectorSellQuartz);\n\t\t}\n\t}\n}\n\nfunction onDrop(it,count) {\n\tif(count >0){\n\t\tif(it == Item.MiningTool0){\n\t\t\ttriggerEvent(Event.FirstLaserLost);\n\t\t}\n\t\tif(it == Item.Radar0){\n\t\t\ttriggerEvent(Event.FirstRadarLost);\n\t\t}\n\t\tif(it == Item.Quartz && !hasCompletedMission(Mission.CraftFTL)){\n\t\t\tvars.quartzSold += count;\n\t\t\tif (vars.quartzSold >=5){\n\t\t\t\ttriggerEvent(Event.FirstSectorSellQuartz);\n\t\t\t}\n\t\t\telse{\n\t\t\t\tunsetEvent(Event.FirstSectorSellQuartz);\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunction onCompleteInstance(inst) {\n\tif (inst == Instance.CorpoTrainingCenter){\n\t\ttriggerEvent(Event.FirstLaserLost);\n\t\ttriggerEvent(Event.FirstRadarLost);\n\t}\n}\n\nfunction onScanResource(res){\n\tswitch( res ) {\n\tcase Resource.MiniGravite_ShelledGravite :\n\t\tdiscoverResource(Resource.ShelledGravite_Encyclopedia,true);\n\t}\n}\n\nfunction onRelocate() {\n\tif(isInShip() && hasItemType (ItemType.Patch)){\n\t\tstartMission(Mission.PatchEquip);\n\t}\n}\n\nfunction onDeploy(b) {\n\tif (b == Item.B_Farm)\n\t\tdiscoverFarmPlant(Farm.EmptyPlot);\n}\n\nfunction onGather(it,count) {\n    discoverItem(Item.Knowledge_Mining);\n}\n\nfunction onStudy(it,count){\n\tdiscoverItem(Item.Knowledge_Science);\n}",
					"guid": "#Ydg-v6GM-cV3",
					"category": "MissionTuto"
				},
				{
					"id": "Intro",
					"requires": [],
					"title": "Talent Acquisition",
					"goal": "Sign your contract with *The Company* and leave *Babylon*.",
					"values": {},
					"steps": [
						{
							"text": "",
							"props": {
								"intercom": "Welcome"
							}
						},
						{
							"text": "Take the elevator to the station's *Dock*.",
							"props": {
								"intercom": "WelcomeP2",
								"end": "dock"
							},
							"cond": "hasEvent(Event.custoDone)"
						},
						{
							"text": "Talk to ::npc.IntroStationAgent:: to start your *Talent Acquisition Procedure*.",
							"props": {
								"npc": "IntroStationAgent"
							},
							"cond": "hasEvent(Event.dock)"
						}
					],
					"event": [
						{
							"id": "dock"
						},
						{
							"id": "debtExplained"
						},
						{
							"id": "firstConditionAccepted"
						},
						{
							"id": "secondConditionAccepted"
						},
						{
							"id": "thirdConditionAccepted"
						},
						{
							"id": "end"
						},
						{
							"id": "custoDone"
						}
					],
					"intercom": [
						{
							"id": "Welcome",
							"text": "Wake up, debtors! Today we're announcing the results of the great *Gig Lottery*!\nThis morning, one of our top 10 maintenance employees will start their very own career as an affiliated worker!\nI know you've been waiting for this, because overall productivity for *Habitation Unit 4E* is up 12% this month.\nYou slackers only start working when the results are close, and it shows. You're supposed to work all the time!\nAnyway, the selected employee for this cycle is...",
							"props": {
								"name": "Quarter Manager Kyle Merzov"
							}
						},
						{
							"id": "WelcomeP2",
							"text": "The *Gig Lottery* employee winner for this cycle is.... *::player::*!\nCongratulations, *::player::*, you're expected on the station’s *dock* immediately.\nAnd now, everyone else get back to work!",
							"props": {
								"name": "Quarter Manager Kyle Merzov"
							}
						}
					],
					"props": {
						"flags": 14,
						"screenshot": "ui/mission_pictures/TalentAquisition.png"
					},
					"script": "function onStart() {\n\thide();\n}\nfunction onCheck(){\n\tif(isInInstance(Instance.DockStart)){\n\t\ttriggerEvent(Event.dock);\n\t}\n}\n\nfunction onSpecialAction(act) {\n\tif( act == SpecialAction.SkinChanged ) {\n\t\tshow();\n\t\tsetEvent(Event.custoDone);\n\t\tstartMission(Mission.TutoIntercomMission);\n\t}\n}",
					"guid": "#Ydg-v6GR-5n0",
					"category": "MissionTuto"
				},
				{
					"id": "Start",
					"title": "OP#00: Space Flight",
					"goal": "Take off and reach ::target::.",
					"values": {
						"target": "Start1",
						"vars": {
							"orientX": 0.1,
							"orientY": 0.1,
							"orientZ": 0.1
						}
					},
					"script": "function onCheck() {\n\tif( planet == mission.target)\n\t\tcomplete();\n\tif(isInShip() && !hasEvent(Event.stopped) && !ship.isDocked() && !hasLockedSequence() /*&& inWindow(\"Intercom\")*/ ) {\n\t\tstopShip();\n\t\ttriggerEvent(Event.stopped);\n\t}\n\tif(isInShip() && hasEvent(Event.stopped) && ship.speed >1){\n\t\ttriggerEvent(Event.knowToAccelerate);\n\t}\n\tif(isInShip() && hasEvent(Event.stopped) && vars.orientX*ship.orient.x + vars.orientY*ship.orient.y + vars.orientZ*ship.orient.z <0.995){\n\t\ttriggerEvent(Event.knowToSteer);\n\t}\n}\n\nfunction onRelocate(){\n\tif(isInShip()){\n\t\tdiscoverItem(Item.Knowledge_ShipControl);\n\t}\n}\n\nfunction onEvent(ev) {\n\tif(ev == Event.stopped){\n\t\tvars.orientX = ship.orient.x;\n\t\tvars.orientY = ship.orient.y;\n\t\tvars.orientZ = ship.orient.z;\n\t}\n\treturn true;\n}",
					"steps": [
						{
							"text": "Board your spaceship and take off from the space station.",
							"props": {}
						},
						{
							"text": "Move the mouse to steer the ship.",
							"props": {
								"subGoal": true
							},
							"group": 1,
							"cond": "ship != null && !ship.isDocked() && !hasEvent(Event.knowToSteer)"
						},
						{
							"text": "Use [key.forward] to accelerate.",
							"props": {
								"subGoal": true
							},
							"cond": "ship != null && !ship.isDocked() && !hasEvent(Event.knowToAccelerate)\n\n",
							"group": 2
						},
						{
							"text": "Control your spaceship to approach ::target:: and enter its atmosphere.",
							"cond": "ship != null && !ship.isDocked() && hasEvent(Event.stopped)",
							"props": {
								"intercom": "Welcome"
							}
						}
					],
					"requires": [
						{
							"mission": "Intro"
						}
					],
					"intercom": [
						{
							"id": "Welcome",
							"text": "Welcome, Recruit #481120, to *The Company*'s *Onboarding Procedure*. By the end of it, your rank will be upgraded to: *Apprentice*.\nMy role is to help you become a skilled, valuable worker. Please note that the cost of this training service is graciously covered by *The Company*.\nYour first tasks will consist of navigating through space in search of basic resources. If you have any questions, please note that you are not allowed to ask them during the *Onboarding Protocol*.",
							"props": {
								"portrait": "TutoNPC"
							}
						}
					],
					"props": {
						"flags": 6,
						"screenshot": "ui/mission_pictures/spaceflight.png"
					},
					"event": [
						{
							"id": "stopped"
						},
						{
							"id": "knowToAccelerate"
						},
						{
							"id": "knowToSteer"
						}
					],
					"guid": "#Ydg-v6GV-Gbb",
					"category": "MissionTuto"
				},
				{
					"id": "FirstGather",
					"title": "OP#01: Mining",
					"goal": "Gather ::count:: ::item:: and ::count2:: ::item2:: in ::target::.",
					"values": {
						"target": "Start1",
						"item": "IronOre",
						"count": 8,
						"item2": "CopperOre",
						"count2": 8,
						"reward": 60
					},
					"steps": [
						{
							"text": "Return to ::target::",
							"props": {}
						},
						{
							"text": "Use [key.backward] to decelerate.",
							"props": {
								"subGoal": true
							},
							"group": 2,
							"cond": "ship != null && !hasEvent(Event.knowToDecelerate)\n\n\n"
						},
						{
							"text": "Use your radar skill [key.RadarPing] to locate nearby resources.",
							"props": {
								"end": "RadarUsed"
							},
							"cond": "planet == mission.target"
						},
						{
							"text": "Use your mining skill [key.Mine] to extract ore and other materials from resource nodes.",
							"props": {
								"end": "ResourceGathered"
							},
							"cond": "planet == mission.target && hasEvent(Event.RadarUsed)"
						}
					],
					"script": "function onStart() {\n    progress(getItemCount(mission.item));\n    progress(getItemCount(mission.item2),true);\n}\n\nfunction onCheck(){\n\tif(planet == mission.target && radarHasDetectedResource()){\n\t\ttriggerEvent(Event.RadarUsed);\n\t}\n\tif(isInShip() && ship.speed <0.5){\n\t\ttriggerEvent(Event.knowToDecelerate);\n\t}\n}\n\nfunction onGather(it,count) {\n    if( it == mission.item )\n        progress(count);\n    if( it == mission.item2 )\n        progress(count, true);\n    if( isProgressFull() )\n\t\ttriggerEvent(Event.ResourceGathered);\n}\n\nfunction onEvent(e){\n\tif(e==Event.ResourceGathered) complete();\n\treturn true;\n}",
					"requires": [
						{
							"mission": "Start"
						}
					],
					"intercom": [
						{
							"id": "End",
							"text": "Now, you might be wondering what to do with all this raw metal. Conveniently enough, we can turn it into your ship's first *upgrade*.\nAnd in turn, that will enable you to gather something more interesting than copper and iron.",
							"props": {
								"portrait": "TutoNPC"
							}
						}
					],
					"props": {
						"flags": 2,
						"screenshot": "ui/mission_pictures/Mining.png"
					},
					"event": [
						{
							"id": "RadarUsed"
						},
						{
							"id": "ResourceGathered"
						},
						{
							"id": "knowToDecelerate"
						}
					],
					"guid": "#Ydg-v6Ga-59C",
					"category": "MissionTuto"
				},
				{
					"id": "FirstCraft",
					"requires": [
						{
							"mission": "FirstGather"
						}
					],
					"title": "OP#02: Ship Upgrade",
					"goal": "Craft ::item:: and install it on your ship.",
					"values": {
						"item": "Scanner0",
						"vars": {
							"smelted": 0
						},
						"reward": 60,
						"targetObj": "Station_Start",
						"permit": "P_Modular0"
					},
					"steps": [
						{
							"text": "Press [key.MenuKnowledges] to access the <t>Knowledge</t> menu, then unlock the ::permit:: permit.",
							"props": {
								"end": "PermitUnlocked"
							},
							"group": 0,
							"cond": "!hasEvent(Event.PermitUnlocked)"
						},
						{
							"text": "Return to the ::target:: space station to craft.",
							"props": {},
							"group": 1,
							"target": {
								"object": "Station_Start"
							}
						},
						{
							"text": "Press [key.Booster] to use your ship’s boosters.",
							"props": {
								"subGoal": true
							},
							"cond": "planet == null && getShip().speed > 0",
							"group": 2
						},
						{
							"text": "Take the elevator to the Shipyard.",
							"props": {},
							"cond": "isInStation()",
							"group": 1
						},
						{
							"text": "Use the Smelter to refine your minerals.",
							"cond": "isInShipyard()",
							"props": {
								"end": "SmelterUsed"
							},
							"group": 1
						},
						{
							"text": "Use the Workshop to craft ::item::.",
							"cond": "isInShipyard() && hasEvent(Event.SmelterUsed)",
							"props": {
								"end": "WorkshopUsed"
							},
							"group": 1
						},
						{
							"text": "Use the Shipyard to install the ::item:: on your ship.",
							"cond": "isInShipyard() && hasEvent(Event.WorkshopUsed)",
							"props": {
								"end": "ScanalyzerInstalled",
								"showInShipEditor": true
							},
							"group": 1
						},
						{
							"text": "Drag the ::item:: from your inventory onto the hull of your ship to install it.",
							"props": {
								"showInShipEditor": true,
								"subGoal": true
							},
							"group": 2,
							"cond": "isInShipEditor()"
						},
						{
							"text": "Click Confirm to leave the ship editor.",
							"props": {
								"showInShipEditor": true,
								"subGoal": true
							},
							"group": 2,
							"cond": "isInShipEditor() && shipEditorItemEquipped(mission.item)"
						},
						{
							"text": "The ::item:: is not correctly connected to the ship hull.",
							"props": {
								"showInShipEditor": true,
								"subGoal": true
							},
							"group": 2,
							"cond": "isInShipEditor() && shipEditorItemEquipped(mission.item) && !canValidateShip()"
						}
					],
					"script": "function onCraft(it,count) {\n    if( it == Item.IronIngot || it == Item.CopperIngot ){\n\t\tvars.smelted += count;\n\t\tif (vars.smelted>5){\n\t\t\ttriggerEvent(Event.SmelterUsed);\n\t\t}\n\t}\n\tif(hasItem(mission.item)) {\n\t\ttriggerEvent(Event.WorkshopUsed);\n\t\tcloseWindow();\n\t}\n}\n\nfunction onEditShip(s) {\n    if( s.hasComponent(mission.item) )\n\t\ttriggerEvent(Event.ScanalyzerInstalled);\n}\n\nfunction onEvent(e){\n\tif(e==Event.ScanalyzerInstalled){\n\t\tcomplete();\n\t}\n\treturn true;\n}\n\nfunction onUnlock(p) {\n\ttriggerEvent(Event.PermitUnlocked);\n\tcloseWindow();\n}",
					"intercom": [
						{
							"id": "End",
							"text": "Congratulations, Recruit #481120, on completing your first set of tasks.\nYour performance has been analyzed and ranked against those of previous contractors. The results are confidential and will not be disclosed to you.\nWith your *scanner* equipped, you can further explore *Solar Alpha* and discover more of its riches. Please keep in mind that your performance is still being recorded.",
							"props": {
								"portrait": "TutoNPC"
							}
						}
					],
					"props": {
						"flags": 2,
						"screenshot": "ui/mission_pictures/ShipUpgrade.png"
					},
					"event": [
						{
							"id": "SmelterUsed"
						},
						{
							"id": "WorkshopUsed"
						},
						{
							"id": "ScanalyzerInstalled"
						},
						{
							"id": "PermitUnlocked"
						}
					],
					"guid": "#Ydg-v6Gd-qaM",
					"category": "MissionTuto"
				},
				{
					"id": "FindQuartz",
					"requires": [
						{
							"mission": "FirstCraft"
						}
					],
					"title": "OP#03: Exotic Resources",
					"goal": "Find, scan, and exploit ::resource::.",
					"values": {
						"target": "Start2",
						"reward": 40,
						"poiIndex": 0,
						"resource": "Quartz_Grey",
						"item": "Quartz",
						"count": 5
					},
					"steps": [
						{
							"text": "Go to ::target:: and enter its atmosphere.",
							"props": {}
						},
						{
							"text": "Press [key.Booster] to use your ship’s boosters.",
							"cond": "planet == null && getShip().speed > 0",
							"props": {
								"subGoal": true
							},
							"group": 2
						},
						{
							"text": "This is the wrong planet. Go to ::target:: and enter its atmosphere.",
							"cond": "planet != null && planet != mission.target",
							"props": {}
						},
						{
							"text": "Find the ::poi:: landmark with your radar.",
							"cond": "planet == mission.target",
							"props": {}
						},
						{
							"text": "Approach ::poi::.",
							"cond": "planet == mission.target && radarHasDetectedResource(planet.getPOI(mission.poiIndex).res)",
							"props": {}
						},
						{
							"text": "Find ::resource:: and scan it.",
							"cond": "planet == mission.target && (radarHasResourcePinned(planet.getPOI(mission.poiIndex).res) || hasResourceTarget(mission.resource))",
							"props": {
								"end": "QuartzScanned"
							}
						},
						{
							"text": "Mine ::resource:: to get ::count:: ::item::.",
							"cond": "planet == mission.target && isResourceScanned(mission.resource)",
							"props": {
								"end": "QuartzGathered"
							}
						}
					],
					"script": "function onScanResource(res){\n\tif (res == mission.resource) {\n\t\tprogress(getItemCount(mission.item));\n\t\ttriggerEvent(Event.QuartzScanned);\n\t}\n}\n\nfunction onGather(it,count) {\n    if( it == mission.item && isResourceScanned(mission.resource))\n        progress(count);\n\tif( isProgressFull() )\n\t\ttriggerEvent(Event.QuartzGathered);\n}\n\nfunction onEvent(e){\n\tif (e==Event.QuartzGathered) complete();\n\treturn true;\n}",
					"intercom": [],
					"props": {
						"flags": 3,
						"screenshot": "ui/mission_pictures/exoressources.png"
					},
					"event": [
						{
							"id": "QuartzScanned"
						},
						{
							"id": "QuartzGathered"
						}
					],
					"guid": "#Ydg-v6Gj-O4U",
					"category": "MissionTuto"
				},
				{
					"id": "ScanPlanet",
					"requires": [
						{
							"mission": "FirstCraft"
						}
					],
					"title": "OP#04: Exploration",
					"goal": "Reach level 1 in *Exploration*.",
					"values": {
						"target": "Start2",
						"resource": "Gravite",
						"reward": 40,
						"permit": "P_Exploration1",
						"vars": {
							"identify": 0
						}
					},
					"steps": [
						{
							"text": "Go to ::target:: and enter its atmosphere.",
							"props": {},
							"cond": "planet == null"
						},
						{
							"text": "This is the wrong planet. Go to ::target:: and enter its atmosphere.",
							"cond": "planet != null && planet != mission.target",
							"props": {}
						},
						{
							"text": "Press [key.Booster] to use your ship’s boosters.",
							"cond": "planet == null && getShip().speed > 0",
							"props": {
								"subGoal": true
							},
							"group": 1
						},
						{
							"text": "Use your radar to approach and identify <bad>::identify::/5</bad> different resources",
							"props": {
								"end": "PlanetDiscovered",
								"endText": "Use your radar to approach and identify <good>5/5</good> different resources"
							},
							"cond": "planet == mission.target && !hasEvent(Event.PlanetDiscovered)\n"
						},
						{
							"text": "Some resources are only present in *landmarks* <img src=\"res/BackgroundPOI1\"/>. Track progress on your map [key.MenuGalaxyMap]",
							"props": {
								"subGoal": true
							},
							"cond": "planet == mission.target && !hasEvent(Event.PlanetDiscovered) && !isResourceScanned(Resource.Quartz_Grey)\n",
							"group": 3
						},
						{
							"text": "Approach and scan [CopperCluster_NativeCopper?]",
							"cond": "!hasEvent(Event.CopperScanned) && !isResourceScanned(Resource.CopperCluster_NativeCopper) && (radarHasDetectedResource(Resource.CopperCluster_NativeCopper) || radarHasResourceAtRange(Resource.CopperCluster_NativeCopper))",
							"props": {
								"end": "CopperScanned"
							},
							"group": 1
						},
						{
							"text": "Approach and scan [IronCluster_NickelIron?]",
							"props": {
								"end": "IronScanned"
							},
							"group": 1,
							"cond": "!hasEvent(Event.IronScanned) && !isResourceScanned(Resource.IronCluster_NickelIron) && (radarHasDetectedResource(Resource.IronCluster_NickelIron) || radarHasResourceAtRange(Resource.IronCluster_NickelIron))"
						},
						{
							"text": "Approach and scan [Quartz_Grey?]",
							"props": {
								"end": "QuartzScanned"
							},
							"group": 1,
							"cond": "!hasEvent(Event.QuartzScanned) && !isResourceScanned(Resource.Quartz_Grey) && (radarHasDetectedResource(Resource.Quartz_Grey) || radarHasResourceAtRange(Resource.Quartz_Grey))"
						},
						{
							"text": "Find a ::resource:: with your radar and approach it.",
							"cond": "planet == mission.target && !hasEvent(Event.GraviteScanned)",
							"props": {},
							"group": 2
						},
						{
							"text": "Locate the ::resource:: with your proximity radar.",
							"cond": "planet == mission.target && radarProximityActive() && !hasEvent(Event.GraviteScanned)",
							"props": {
								"intercom": "ProxyRadarExplained"
							},
							"group": 2
						},
						{
							"text": "Scan the ::resource:: to extract gravitational data.",
							"cond": "planet == mission.target && hasResourceTarget(mission.resource) && !hasEvent(Event.GraviteScanned)",
							"props": {
								"end": "GraviteScanned"
							},
							"group": 2
						}
					],
					"script": "function sync() {\n\tvar p = getTargetPlanet();\n\tvars.identify = p.countIdentifiedResources();\n\tsetProgress(getPlayerLevelXP(Attribute.Exploration));\n}\n\nfunction onStart() {\n\tsync();\n\tif( isResourceScanned(Resource.CopperCluster_NativeCopper) ) setEvent(Event.CopperScanned);\n\tif( isResourceScanned(Resource.IronCluster_NickelIron) ) setEvent(Event.IronScanned);\n\tif( isResourceScanned(Resource.Quartz_Grey) ) setEvent(Event.QuartzScanned);\n}\n\nfunction onDiscoverPlanet(p) {\n    if( p == mission.target ) {\n        if( p.isExplored())\n            triggerEvent(Event.PlanetDiscovered);\n\t\tsync();\n    }\n}\n\nfunction onScanResource(res){\n\tsync();\n\tswitch( res ) {\n\tcase Resource.Gravite:\n\t\tsetEvent(Event.GraviteScanned);\n\tcase Resource.CopperCluster_NativeCopper:\n\t\tsetEvent(Event.CopperScanned);\n\tcase Resource.IronCluster_NickelIron:\n\t\tsetEvent(Event.IronScanned);\n\tcase Resource.Quartz_Grey:\n\t\tsetEvent(Event.QuartzScanned);\n\t}\n}\n\nfunction onCheck(){\n\tif(planet == mission.target && radarProximityActive()){\n\t\ttriggerEvent(Event.NearGravite);\n\t}\n}\n\nfunction onEvent(e){\n\tif (e==Event.NearGravite){\n\t\tdiscoverResource(Resource.Gravite,true);\n\t}\n\treturn true;\n}\n\nfunction onUnlock(p){\n\tif (p == mission.permit){\n\t\tdiscoverItem(Item.Knowledge_Exploration);\n\t\tcomplete();\n\t}\n}",
					"intercom": [
						{
							"id": "ProxyRadarExplained",
							"text": "*Gravite stones* have unique radio properties preventing your *radar* from pinpointing their exact position. Starting from an approximate direction, you will have to locate each gravite deposit visually.",
							"props": {
								"portrait": "TutoNPC"
							}
						}
					],
					"props": {
						"flags": 3,
						"screenshot": "ui/mission_pictures/explo.png"
					},
					"event": [
						{
							"id": "GraviteScanned"
						},
						{
							"id": "NearGravite"
						},
						{
							"id": "PlanetDiscovered"
						},
						{
							"id": "CopperScanned"
						},
						{
							"id": "IronScanned"
						},
						{
							"id": "QuartzScanned"
						}
					],
					"guid": "#Ydg-v6Gl-TXG",
					"category": "MissionTuto"
				},
				{
					"id": "MerchantLicense",
					"requires": [
						{
							"mission": "FirstCraft"
						}
					],
					"title": "OP#05: Trading",
					"goal": "Trade with the The Company Exchanger.",
					"values": {
						"count": 40,
						"reward": 40,
						"targetObj": "Station_Start",
						"item2": "SiliconeGel",
						"count2": 10
					},
					"steps": [
						{
							"text": "Return to space station.",
							"props": {},
							"cond": "!isInStation()"
						},
						{
							"text": "Go to the station shipyard and find The Company Exchanger.",
							"props": {},
							"cond": "isInStation() && !isInShipyard()"
						},
						{
							"text": "Sell <price>::count::</price> worth of resources.",
							"cond": "isInShipyard() && !hasEvent(Event.SaleDone)",
							"props": {
								"end": "SaleDone"
							},
							"group": 1
						},
						{
							"text": "Buy ::count2:: ::item2::.",
							"cond": "isInShipyard() && !hasEvent(Event.PurchaseDone)",
							"props": {
								"end": "PurchaseDone"
							},
							"group": 2
						}
					],
					"intercom": [],
					"props": {
						"flags": 3,
						"screenshot": "ui/mission_pictures/trading.png"
					},
					"script": "function onTrade(it, count) {\n    if( count > 0 ) {\n        var p = getTotalSold() / mission.count;\n        setProgress(p);\n\t\tif(p>=1) triggerEvent(Event.SaleDone);\n    }\n\telse{\n\t\tif (it==mission.item2){\n\t\t\tprogress(-count,true);\n\t\t\tif( mission.currentCount2 >= mission.count2 )\n\t\t\t\ttriggerEvent(Event.PurchaseDone);\n\t\t}\n\t}\n\tif( isProgressFull() ) {\n\t\tcloseWindow(true);\n\t\tcomplete();\n\t}\n}",
					"event": [
						{
							"id": "SaleDone"
						},
						{
							"id": "PurchaseDone"
						}
					],
					"guid": "#Ydg-v6Gp-KOT",
					"category": "MissionTuto"
				},
				{
					"id": "CraftFTL",
					"requires": [
						{
							"mission": "ScanPlanet"
						},
						{
							"mission": "FindQuartz"
						},
						{
							"mission": "MerchantLicense"
						}
					],
					"title": "OP#06: Interstellar Travel",
					"goal": "Craft ::item:: and use it to travel to another solar system.",
					"values": {
						"reward": 100,
						"vars": {
							"engine": false
						},
						"permit": "P_CrystalOptic",
						"item": "FTLEngine1",
						"system": "Sys_Start",
						"item2": "Focuser"
					},
					"steps": [
						{
							"text": "Unlock the ::permit:: permit.",
							"props": {
								"intercom": "Welcome"
							}
						},
						{
							"text": "Press [key.MenuOpen] and click on the *Knowledge* section.",
							"props": {
								"subGoal": true
							},
							"cond": "!canCraft(mission.item2)",
							"group": 1
						},
						{
							"text": "Craft ::item:: and install it on your ship.",
							"cond": "canCraft(mission.item2)",
							"props": {
								"showInShipEditor": true
							}
						},
						{
							"text": "Drag the ::item:: from your inventory into a module slot inside your ship to install it.",
							"props": {
								"showInShipEditor": true,
								"subGoal": true
							},
							"group": 1,
							"cond": "isInShipEditor() && hasItem(mission.item) && !shipEditorItemEquipped(mission.item)"
						},
						{
							"text": "[Quartz] are available in the The Company Exchanger.",
							"props": {
								"subGoal": true
							},
							"cond": "canCraft(mission.item2) && !vars.engine && !hasItem(mission.item) && !hasItem(mission.item2) && !hasItem(Item.Quartz)",
							"group": 2
						},
						{
							"text": "Enter your ship.",
							"cond": "canCraft(mission.item2) && vars.engine",
							"props": {}
						},
						{
							"text": "Fill the ship’s [FTOil] before taking off.",
							"cond": "canCraft(mission.item2) && vars.engine && ship != null",
							"props": {}
						},
						{
							"text": "Take off.",
							"cond": "canCraft(mission.item2) && vars.engine && ship != null && ship.isFullOil()",
							"props": {}
						},
						{
							"text": "Fill the ship’s [FTOil] at the station.",
							"cond": "canCraft(mission.item2) && vars.engine && !isInStation() && ship != null && ship.ftoil == 0",
							"props": {}
						},
						{
							"text": "Target a nearby star which can be reached via FTL jump.",
							"cond": "canCraft(mission.item2) && vars.engine && ship != null && ship.isFullOil() && !isInStation()",
							"props": {}
						},
						{
							"text": "Perform an FTL jump using [key.Travel].",
							"cond": "canCraft(mission.item2) && vars.engine && ship != null && ship.isFullOil() && hasSystemTarget()",
							"props": {}
						}
					],
					"script": "function onStart(){\n\tvars.engine = getShip().hasComponent(mission.item);\n}\n\nfunction onUnlock(p) {\n\tif( p == mission.permit )\n\t\tcloseWindow();\n}\n\nfunction onEditShip(s) {\n    vars.engine = s.hasComponent(mission.item);\n}\nfunction onCheck() {\n\tif( getSystem() != mission.system && !hasLockedSequence() ){\n\t\tcomplete();\n\t}\n}",
					"intercom": [
						{
							"id": "Welcome",
							"text": "Congratulations, Recruit #481120. You seem to have explored most of what *Solar Alpha* has to offer.\nMy final responsibility is to open the doors of the universe to you. That means guiding you through the process of acquiring an *FTL engine*.",
							"props": {
								"portrait": "TutoNPC"
							}
						}
					],
					"props": {
						"flags": 2,
						"screenshot": "ui/mission_pictures/interstelartravel.png"
					},
					"event": [],
					"guid": "#Ydg-v6Gv-5FO",
					"category": "MissionTuto"
				},
				{
					"id": "SkinEquip",
					"requires": [],
					"title": "A new space suit!",
					"goal": "Change your suit by opening the character menu [key.MenuCharacter]",
					"values": {},
					"steps": [],
					"event": [],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/SkinEquip.png"
					},
					"script": "function onSpecialAction(act) {\n\tif( act == SpecialAction.SkinChanged ) complete();\n}",
					"guid": "#Ydg-v6Gz-Guq",
					"category": "MissionTuto"
				},
				{
					"id": "PatchEquip",
					"guid": "#a3x-xgrJ-x&q",
					"requires": [],
					"title": "Patchwork",
					"goal": "Install a patch on a module",
					"values": {},
					"steps": [
						{
							"text": "Go to any station shipyard.",
							"props": {}
						},
						{
							"text": "Find a suitable module to install a patch from your inventory.",
							"props": {},
							"cond": "isInShipyard()"
						},
						{
							"text": "Talk with the ::npc:: and install a patch on a module.",
							"props": {
								"npc": "ShipYardStation_npc_ShipyardClerk"
							},
							"group": 1,
							"cond": "isInShipyard()"
						}
					],
					"event": [],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/PatchEquip.png"
					},
					"script": "function onCheck() {\n\tif(!hasItemType(ItemType.Patch)){\n\t\tfail();\n\t}\n}\n\nfunction onSpecialAction(act) {\n\tif( act == SpecialAction.InstallPatch ) complete();\n}",
					"category": "MissionTuto"
				},
				{
					"id": "OuterSpaceTuto",
					"guid": "#bLi-MkOy-dFg",
					"requires": [],
					"title": "System Border",
					"goal": "",
					"values": {},
					"steps": [],
					"event": [],
					"intercom": [
						{
							"id": "Deny",
							"text": "You are not allowed to leave the system with conventional propulsion while onboarding is in progress.",
							"props": {
								"portrait": "TutoNPC"
							}
						}
					],
					"props": {},
					"script": "",
					"category": "MissionTuto"
				},
				{
					"id": "ReachThresholdStation",
					"requires": [
						{
							"mission": "CraftFTL"
						}
					],
					"title": "Contractor Orientation Missions",
					"goal": "Travel to ::target-raw:: station and meet with its clerk.",
					"values": {
						"targetObj": "Station_Threshold",
						"count": 3,
						"reward": 50
					},
					"steps": [
						{
							"text": "Go to ::target::.",
							"props": {},
							"cond": "!hasEvent(Event.Pitched)"
						},
						{
							"text": "Go to ::target::.",
							"props": {
								"intercom": "Welcome"
							},
							"cond": "!hasEvent(Event.Reached)"
						},
						{
							"text": "Use your Galaxy Map with [key.MenuGalaxy] to help in your travel.",
							"props": {
								"subGoal": true
							},
							"group": 1,
							"cond": "getSystem() != mission.target && (!hasEvent(Event.Pitched) || !hasEvent(Event.Reached))"
						},
						{
							"text": "Dock on ::target:: station.",
							"cond": "!hasEvent(Event.Pitched) && getSystem() == mission.target.system",
							"props": {}
						},
						{
							"text": "Talk to the clerk, ::npc.CivilStation_WelcomeNpc::.",
							"cond": "!hasEvent(Event.Pitched) && isInStation() && (getSystem() == mission.target.system)",
							"props": {
								"npc": "CivilStation_WelcomeNpc",
								"end": "ClerkMet"
							}
						},
						{
							"text": "Listen carefully to \"the pitch\".",
							"props": {},
							"cond": "hasEvent(Event.ClerkMet)&&!hasEvent(Event.Pitched)"
						},
						{
							"text": "Finish talking with ::npc.CivilStation_WelcomeNpc::.",
							"props": {},
							"cond": "hasEvent(Event.Pitched)&&!hasEvent(Event.FinishedTalking)"
						},
						{
							"text": "Greet ::npc.CivilStation_ShipAdvisor::, the dock officer.",
							"props": {
								"npc": "CivilStation_ShipAdvisor",
								"end": "NPC1_Quested"
							},
							"group": 1,
							"cond": "hasEvent(Event.NPC1_Introduced) && !hasEvent(Event.NPC1_Quested)"
						},
						{
							"text": "Join ::npc.CivilStation_CorpoManager::'s training program.",
							"props": {
								"npc": "CivilStation_CorpoManager",
								"end": "NPC3_Quested"
							},
							"group": 3,
							"cond": "hasEvent(Event.NPC3_Introduced) && !hasEvent(Event.NPC3_Quested)"
						},
						{
							"text": "Visit the <target>Mining Bureau</target> using the station elevator.",
							"props": {},
							"group": 4,
							"cond": "hasEvent(Event.NPC4_Introduced) && !hasEvent(Event.NPC4_Quested)"
						},
						{
							"text": "Meet ::npc.MiningBureau_npc::, the bureau officer, and enter the integration protocol.",
							"props": {
								"end": "NPC4_Quested",
								"npc": "MiningBureau_npc"
							},
							"group": 4,
							"cond": "hasEvent(Event.NPC4_Introduced) && !hasEvent(Event.NPC4_Quested) && isInInstance(Instance.MiningBureau)"
						}
					],
					"event": [
						{
							"id": "Reached"
						},
						{
							"id": "ClerkMet"
						},
						{
							"id": "Pitched"
						},
						{
							"id": "NPC1_Introduced"
						},
						{
							"id": "NPC1_Quested"
						},
						{
							"id": "NPC2_Introduced"
						},
						{
							"id": "NPC2_Quested"
						},
						{
							"id": "NPC3_Introduced"
						},
						{
							"id": "NPC3_Quested"
						},
						{
							"id": "NPC4_Introduced"
						},
						{
							"id": "NPC4_Quested"
						},
						{
							"id": "FinishedTalking"
						}
					],
					"intercom": [
						{
							"id": "Welcome",
							"text": "You are now equipped with a tool of absolute freedom. Take a moment to appreciate that the distances you are now able to travel were unfathomable to all but the last few generations of humans.\nBy completing *The Company*'s *Onboarding Procedure*, you have reached the rank of *Apprentice*, which makes you a citizen and an interstellar traveler.\nNow you should head to *Raqmu* station, where you can start the *Orientation Missions* and reach *Partner* rank. *Raqmu* is located in the *Threshold Sector*, just a few FTL jumps away. But as of now, I am not responsible for anything you do. In fact, no one is.\n*The Company*: Today and Tomorrow.",
							"props": {
								"portrait": "TutoNPC"
							}
						}
					],
					"props": {
						"screenshot": "ui/mission_pictures/Contractor Autonomization Missions.png"
					},
					"script": "function onStart(){\n\t\tdiscoverItem(Item.Knowledge_FTL);\n}\n\nfunction onRelocate() {\n\tif( isInStation(getTarget()) ) setEvent(Event.Reached);\n}\nfunction onCheck(){\n\tif( hasEvent(Event.NPC1_Introduced) && hasMission(Mission.UpgradeTheShip,true) ){\n\t\ttriggerEvent(Event.NPC1_Quested);\n\t}\n\t/*if( hasEvent(Event.NPC2_Introduced) && hasMission(Mission.FirstBase,true) ){\n\t\ttriggerEvent(Event.NPC2_Quested);\n\t}*/\n\tif( hasEvent(Event.NPC3_Introduced) && hasMission(Mission.CorpoTraining,true) ){\n\t\ttriggerEvent(Event.NPC3_Quested);\n\t}\n\tif( hasEvent(Event.NPC4_Introduced) && hasMission(Mission.Bureau01, true) ){\n\t\ttriggerEvent(Event.NPC4_Quested);\n\t}\n}\n\nfunction onEvent(e){\n\tswitch e{\n\t\tcase Event.NPC1_Introduced:\n\t\t\tif (hasMission(Mission.UpgradeTheShip) || hasCompletedMission(Mission.UpgradeTheShip)) triggerEvent(Event.NPC1_Quested);\n\t\t/*case Event.NPC2_Introduced:\n\t\t\tif (hasMission(Mission.FirstBase) || hasCompletedMission(Mission.FirstBase)) triggerEvent(Event.NPC2_Quested);*/\n\t\tcase Event.NPC3_Introduced:\n\t\t\tif (hasMission(Mission.CorpoTraining) || hasCompletedMission(Mission.CorpoTraining)) triggerEvent(Event.NPC3_Quested);\n\t\tcase Event.NPC4_Introduced:\n\t\t\tif (hasMission(Mission.Bureau01) || hasCompletedMission(Mission.Bureau01)) triggerEvent(Event.NPC3_Quested);\n\t\t\tstartMission(Mission.TutoIntercomMission);\n\t\tcase Event.NPC1_Quested, Event.NPC2_Quested, Event.NPC3_Quested, Event.NPC4_Quested:\n\t\t\tprogress(1);\n\t\t\tif( isProgressFull() ) complete();\n\t}\n\treturn true;\n}",
					"guid": "#Ydg-v6H&-FXV",
					"category": "MissionTuto2"
				},
				{
					"id": "UpgradeTheShip",
					"requires": [],
					"title": "Gradual Enhancement",
					"goal": "Improve your ship's basic tools.",
					"values": {
						"count": 3,
						"reward": 150
					},
					"steps": [
						{
							"text": "Make ::count:: of the following upgrades:",
							"props": {
								"end": "EnoughUpgrades"
							},
							"group": 1,
							"cond": "!hasEvent(Event.EnoughUpgrades)"
						},
						{
							"text": "Install a better mining laser.",
							"props": {
								"end": "BetterMiningLaser",
								"subGoal": true
							},
							"group": 2,
							"cond": "!hasEvent(Event.EnoughUpgrades)"
						},
						{
							"text": "Install a better resource detector.",
							"props": {
								"end": "BetterRadar",
								"subGoal": true
							},
							"group": 3,
							"cond": "!hasEvent(Event.EnoughUpgrades)"
						},
						{
							"text": "Increase your cargo hold size.",
							"props": {
								"end": "BetterStorage",
								"subGoal": true
							},
							"group": 4,
							"cond": "!hasEvent(Event.EnoughUpgrades)"
						},
						{
							"text": "Install a better battery.",
							"props": {
								"end": "BetterBatteries",
								"subGoal": true
							},
							"group": 5,
							"cond": "!hasEvent(Event.EnoughUpgrades)"
						},
						{
							"text": "Change your ship's name in the shipyard.",
							"props": {
								"end": "RenamedShip"
							},
							"cond": "hasEvent(Event.EnoughUpgrades)"
						},
						{
							"text": "Come back to ::npc.CivilStation_ShipAdvisor:: on ::target::'s dock.",
							"props": {
								"npc": "CivilStation_ShipAdvisor"
							},
							"cond": "hasEvent(Event.EnoughUpgrades) && hasEvent(Event.RenamedShip)",
							"target": {
								"object": "Station_Threshold"
							}
						}
					],
					"event": [
						{
							"id": "BetterMiningLaser"
						},
						{
							"id": "BetterRadar"
						},
						{
							"id": "BetterStorage"
						},
						{
							"id": "BetterBatteries"
						},
						{
							"id": "EnoughUpgrades"
						},
						{
							"id": "RenamedShip"
						}
					],
					"intercom": [],
					"props": {
						"flags": 8,
						"screenshot": "ui/mission_pictures/Gradual Enhancement.png"
					},
					"script": "function onStart(){\n\tcheckShipUpgrade(getShip());\n\tstartMission(Mission.UpgradeTheShip_ModuleManagement);\n}\n\nfunction onEditShip(s) {\n\tcheckShipUpgrade(s);\n}\n\nfunction checkShipUpgrade(s){\n\tif( s == null || s.isCorpo() ) return;\n\tvar upgradeCount = 0;\n\tif(s.getAttribute(Attribute.MiningTier,Skill.Mine) > 1) {\n\t\ttriggerEvent(Event.BetterMiningLaser);\n\t\tupgradeCount++;\n\t}\n\telse {\n\t\tunsetEvent(Event.BetterMiningLaser);\n\t}\n\tif(s.getAttribute(Attribute.RadarRange,Skill.RadarPing) > 10) {\n\t\ttriggerEvent(Event.BetterRadar);\n\t\tupgradeCount++;\n\t}\n\telse {\n\t\tunsetEvent(Event.BetterRadar);\n\t}\n\tif(s.getAttribute(Attribute.SolidStorage) > 150) {\n\t\ttriggerEvent(Event.BetterStorage);\n\t\tupgradeCount++;\n\t}\n\telse {\n\t\tunsetEvent(Event.BetterStorage);\n\t}\n\tif(s.getAttribute(Attribute.PowerStorage) > 1200) {\n\t\ttriggerEvent(Event.BetterBatteries);\n\t\tupgradeCount++;\n\t}\n\telse {\n\t\tunsetEvent(Event.BetterBatteries);\n\t}\n\tsetProgress(upgradeCount/mission.count);\n\tif(isProgressFull()){\n\t\ttriggerEvent(Event.EnoughUpgrades);\n\t}\n\telse{\n\t\tunsetEvent(Event.EnoughUpgrades);\n\t}\n\tif(s.name == \"Scrappy Pioneer\"){\n\t\tunsetEvent(Event.RenamedShip);\n\t}\n\telse{\n\t\ttriggerEvent(Event.RenamedShip);\n\t}\n}",
					"guid": "#Ydg-v6H5-UAq",
					"category": "MissionTuto2"
				},
				{
					"id": "UpgradeTheShip2",
					"requires": [
						{
							"mission": "UpgradeTheShip"
						}
					],
					"title": "Tools of the Trade",
					"goal": "Improve your ship above ::count:: pts.",
					"values": {
						"count": 600,
						"phReward": "badge",
						"reward": 200
					},
					"steps": [
						{
							"text": "Add more modules to your ship.",
							"props": {
								"end": "CountReached"
							},
							"group": 1,
							"cond": ""
						}
					],
					"event": [
						{
							"id": "CountReached"
						},
						{
							"id": "TestEvent"
						}
					],
					"intercom": [
						{
							"id": "End",
							"text": "Well done! At this point, you're approaching the limit of what can be done with modules alone.\nYou see, everything you add to your ship is powered by her internal system. If the System Requirements of your modules exceed the System Support of your hull, things won’t work as well any more.\nLong story short: if you want to keep improving your ship, you’ll need to upgrade her engine, and then her hull.",
							"props": {
								"portrait": "CivilStation_ShipAdvisor"
							}
						}
					],
					"props": {
						"screenshot": "ui/mission_pictures/Tools of the Trade.png"
					},
					"script": "function onStart(){\n\t// don't check at start (wait for TestEvent)\n}\n\nfunction onEditShip(s) {\n\tcheckShipUpgrade(s);\n}\n\nfunction checkShipUpgrade(s){\n\tif( s == null || s.isCorpo() ) return;\n\tsetValue(s.getPoints());\n\tif(isProgressFull())\n\t\tcomplete();\n}\n\nfunction onEvent(e){\n\tif( e == Event.TestEvent )\n\t\tcheckShipUpgrade(getShip());\n\treturn true;\n}",
					"guid": "#Ydg-v6H8-Q9B",
					"category": "MissionTuto2"
				},
				{
					"id": "UpgradeTheShip2_1",
					"guid": "#aJd-UND3-#kC",
					"requires": [
						{
							"mission": "UpgradeTheShip2"
						}
					],
					"title": "Double Trouble",
					"goal": "Improve your ship’s engine force.",
					"values": {
						"phReward": "badge",
						"permit": "P_EngineCrafting",
						"reward": 200
					},
					"steps": [
						{
							"text": "Unlock the ::permit:: permit.",
							"props": {}
						},
						{
							"text": "Craft and install a second thruster on your ship.",
							"props": {
								"end": "EngineSet",
								"showInShipEditor": true
							},
							"cond": "hasPermit(mission.permit)\n"
						},
						{
							"text": "Drag a part from your inventory over the ship view to add it.",
							"props": {
								"showInShipEditor": true,
								"subGoal": true
							},
							"group": 1,
							"cond": "isInShipEditor() && isInShipEditorAssembly() && hasItem(Item.Thruster0)"
						},
						{
							"text": "Parts can be added from the Assembly tab.",
							"props": {
								"showInShipEditor": true,
								"subGoal": true
							},
							"group": 1,
							"cond": "isInShipEditor() && !isInShipEditorAssembly() && hasItem(Item.Thruster0)"
						}
					],
					"event": [
						{
							"id": "EngineSet"
						}
					],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/UpgradeTheShip2_1.png"
					},
					"script": "function onStart(){\n\tcheckShipUpgrade(getShip());\n}\n\nfunction onEditShip(s) {\n\tcheckShipUpgrade(s);\n}\n\nfunction checkShipUpgrade(s){\n\tif( s == null || s.isCorpo() ) return;\n\tif(s.getAttribute(Attribute.EngineForce)>300){\n\t\ttriggerEvent(Event.EngineSet);\n\t}\n}\n\nfunction onEvent(e){\n\tif (e==Event.EngineSet){\n\t\tcomplete();\n\t}\n\treturn true;\n}\n",
					"category": "MissionTuto2"
				},
				{
					"id": "UpgradeTheShip3",
					"requires": [
						{
							"mission": "UpgradeTheShip2_1"
						}
					],
					"title": "Structural Changes",
					"goal": "Improve your ship above ::count:: pts.",
					"values": {
						"count": 800,
						"permit": "P_ShipCrafting",
						"reward": 500
					},
					"steps": [
						{
							"text": "Unlock the ::permit:: permit.",
							"props": {}
						},
						{
							"text": "Craft and install a ship part on your ship.",
							"props": {},
							"cond": "hasPermit(mission.permit)"
						},
						{
							"text": "Add more ship parts and modules to your ship.",
							"props": {
								"end": "CountReached"
							},
							"cond": "hasPermit(mission.permit)&&hasEvent(Event.ShipPartInstalled)"
						}
					],
					"event": [
						{
							"id": "CountReached"
						},
						{
							"id": "ShipPartInstalled"
						}
					],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/Structural Change.png"
					},
					"script": "function onStart(){\n\tcheckShipUpgrade(getShip());\n}\n\nfunction onEditShip(s) {\n\tcheckShipUpgrade(s);\n}\n\nfunction checkShipUpgrade(s){\n\tif( s == null || s.isCorpo() ) return;\n\tif(s.getAttribute(Attribute.Hull)>188||s.getAttribute(Attribute.SystemSupport)>1621){\n\t\ttriggerEvent(Event.ShipPartInstalled);\n\t}\n\tsetValue(s.getPoints());\n\tif(isProgressFull()){\n\t\ttriggerEvent(Event.CountReached);\n\t}\n}\n\nfunction onEvent(e){\n\tif (e==Event.CountReached){\n\t\tcomplete();\n\t}\n\treturn true;\n}",
					"guid": "#Ydg-v6HD-ZSM",
					"category": "MissionProgress"
				},
				{
					"id": "UpgradeTheShip4",
					"guid": "#Yk&-D#CN-#ka",
					"requires": [
						{
							"mission": "UpgradeTheShip3"
						}
					],
					"title": "Material Improvements",
					"goal": "Improve your ship above ::count:: pts.",
					"values": {
						"count": 2000,
						"reward": 1000
					},
					"steps": [
						{
							"text": "Add even more ship parts and modules to your ship.",
							"props": {
								"end": "CountReached"
							}
						}
					],
					"event": [
						{
							"id": "CountReached"
						}
					],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/UpgradeTheShip4.png"
					},
					"script": "function onStart(){\n\tcheckShipUpgrade(getShip());\n}\n\nfunction onEditShip(s) {\n\tcheckShipUpgrade(s);\n}\n\nfunction checkShipUpgrade(s){\n\tif( s == null || s.isCorpo() ) return;\n\tsetValue(s.getPoints());\n\tif(isProgressFull()){\n\t\ttriggerEvent(Event.CountReached);\n\t}\n}\n\nfunction onEvent(e){\n\tif (e==Event.CountReached){\n\t\tcomplete();\n\t}\n\treturn true;\n}",
					"category": "MissionProgress"
				},
				{
					"id": "UpgradeTheShip_ModuleManagement",
					"requires": [],
					"title": "Module Management",
					"goal": "Fiddle with the efficiency of your ship's skills.",
					"values": {},
					"steps": [
						{
							"text": "Configure your laser mining skill by disabling one of the two lasers.",
							"props": {
								"intercom": "BadLaserUsed"
							},
							"group": 1,
							"cond": "hasEvent(Event.BadLaserUsed) && !hasEvent(Event.LaserConfigured)"
						},
						{
							"text": "Configure your radar skill or keep only one resource detector on your ship.",
							"props": {
								"intercom": "BadRadarUsed"
							},
							"group": 2,
							"cond": "hasEvent(Event.BadRadarUsed) && !hasEvent(Event.RadarConfigured)"
						},
						{
							"text": "Configure a skill by using <img src=\"icon/RightClick\"/> on the skill in the ship menu [key.MenuShip].",
							"props": {},
							"group": 3
						}
					],
					"event": [
						{
							"id": "BadLaserUsed"
						},
						{
							"id": "BadRadarUsed"
						},
						{
							"id": "LaserConfigured"
						},
						{
							"id": "RadarConfigured"
						}
					],
					"intercom": [
						{
							"id": "BadLaserUsed",
							"text": "Two *lasers* already? You're voracious, I like that! Make sure your system has enough power to use both *lasers* to their full potential, though. Otherwise, you can adjust your *mining skill* to send all the juice to just one of them.",
							"props": {
								"portrait": "CivilStation_ShipAdvisor"
							}
						},
						{
							"id": "BadRadarUsed",
							"text": "Why'd you have two resource detectors installed on that ship? You can't detect something twice, mate. It's good that you're trying new things, but just make sure you adjust your radar skill so you’re not wasting battery on two detectors.",
							"props": {
								"portrait": "CivilStation_ShipAdvisor"
							}
						}
					],
					"props": {
						"flags": 4,
						"screenshot": "ui/mission_pictures/ModuleManagement.png"
					},
					"script": "function onStart(){\n\thide();\n}\n\nfunction onGather(it,count){\n\tship = getShip();\n\tif(ship.getModuleItemCount(Skill.Mine)>1 && !hasEvent(Event.BadLaserUsed)){\n\t\ttriggerEvent(Event.BadLaserUsed);\n\t}\n}\n\nfunction onCheck(){\n\tship = getShip();\n\tif(planet != null && radarHasDetectedResource() && ship.getModuleItemCount(Skill.RadarPing)>1 && !hasEvent(Event.BadRadarUsed)){\n\t\ttriggerEvent(Event.BadRadarUsed);\n\t}\n}\n\nfunction onEvent(e){\n\tswitch(e){\n\t\tcase Event.BadLaserUsed:\n\t\t\tcheckLaserEvents(getShip());\n\t\tcase Event.BadRadarUsed:\n\t\t\tcheckRadarEvents(getShip());\n\t\tcase Event.LaserConfigured:\n\t\t\tif (hasEvent(Event.RadarConfigured)) fail();\n\t\tcase Event.RadarConfigured:\n\t\t\tif (hasEvent(Event.LaserConfigured)) fail();\n\t}\n\treturn true;\n}\n\nfunction onEditShip(s){\n\tif(hasEvent(Event.BadLaserUsed) && !hasEvent(Event.LaserConfigured)){\n\t\tcheckLaserEvents(s);\n\t}\n\tif(hasEvent(Event.BadRadarUsed) && !hasEvent(Event.RadarConfigured)){\n\t\tcheckRadarEvents(s);\n\t}\n}\n\nfunction checkLaserEvents(s){\n\tif (s.getModuleItemCount(Skill.Mine,true)<=1){\n\t\tunsetEvent(Event.BadLaserUsed);\n\t\tcheckRadarForHide();\n\t}\n\telse if(s.getModuleItemCount(Skill.Mine)>0 && s.getModuleItemCount(Skill.Mine) < s.getModuleItemCount(Skill.Mine,true)){\n\t\ttriggerEvent(Event.LaserConfigured);\n\t\tcheckRadarForHide();\n\t}\n\telse show();\n}\n\nfunction checkRadarEvents(s){\n\tif (s.getModuleItemCount(Skill.RadarPing,true)<=1){\n\t\ttriggerEvent(Event.RadarConfigured);\n\t\tcheckLaserForHide();\n\t}\n\telse if(s.getModuleItemCount(Skill.RadarPing)>0 && s.getModuleItemCount(Skill.RadarPing) < s.getModuleItemCount(Skill.RadarPing,true)){\n\t\ttriggerEvent(Event.RadarConfigured);\n\t\tcheckLaserForHide();\n\t}\n\telse show();\n}\n\n\nfunction checkLaserForHide(){\n\tif (hasEvent(Event.BadLaserUsed) && !hasEvent(Event.LaserConfigured)){\n\t\tshow();\n\t}\n\telse hide();\n}\n\nfunction checkRadarForHide(){\n\tif (hasEvent(Event.BadRadarUsed) && !hasEvent(Event.RadarConfigured)){\n\t\tshow();\n\t}\n\telse hide();\n}",
					"guid": "#Ydg-v6HG-mTF",
					"category": "MissionProgress"
				},
				{
					"id": "CustoShip1",
					"guid": "#bIw-zdIx-ICY",
					"requires": [
						{
							"mission": "UpgradeTheShip"
						}
					],
					"title": "Coating",
					"goal": "Change your ship color.",
					"values": {
						"permit": "P_ShipColors",
						"reward": 10
					},
					"steps": [
						{
							"text": "Edit your ship and change its *color*.",
							"props": {
								"showInShipEditor": true
							}
						},
						{
							"text": "Reach nearest station's *Shipyard*",
							"props": {},
							"cond": "!isInShipyard()"
						},
						{
							"text": "Unlock the ::permit:: permit",
							"props": {},
							"cond": "!hasPermit(mission.permit)"
						}
					],
					"event": [],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/CustoShip1.png"
					},
					"script": "function onEditShip(s) {\n\tif( s.editProps.hasChangedColor ) complete();\n}",
					"category": "MissionProgress"
				},
				{
					"id": "CustoShip2",
					"guid": "#bIw-ztJ#-k#N",
					"requires": [
						{
							"mission": "CustoShip1"
						}
					],
					"title": "Decals for fun",
					"goal": "Decorate your ship with *decals*.",
					"values": {
						"permit": "P_ShipDecals",
						"reward": 10
					},
					"steps": [
						{
							"text": "Edit your ship and add a *decal*.",
							"props": {
								"showInShipEditor": true
							}
						},
						{
							"text": "Reach nearest station's *Shipyard*",
							"props": {},
							"cond": "!isInShipyard()"
						},
						{
							"text": "Unlock the ::permit:: permit",
							"props": {},
							"cond": "!hasPermit(mission.permit)"
						}
					],
					"event": [],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/CustoShip2.png"
					},
					"script": "function onEditShip(s) {\n\tif( s.editProps.hasAddedDecal ) complete();\n}",
					"category": "MissionProgress"
				},
				{
					"id": "CorpoTraining",
					"requires": [],
					"title": "Cognitive and Physical Assessment",
					"goal": "Complete the required test to obtain the *Novitiate* rank.",
					"values": {
						"reward": 150
					},
					"steps": [
						{
							"text": "Reach ::target::.",
							"props": {},
							"target": {
								"instance": "CorpoTrainingCenter"
							},
							"group": 1,
							"cond": ""
						},
						{
							"text": "Land on the platform using [key.Descend].",
							"props": {},
							"cond": "ship != null && getDistance(getTarget()) < 1000",
							"target": {
								"instance": "CorpoTrainingCenter"
							},
							"group": 1
						},
						{
							"text": "Enter the ::target:: location's main entrance",
							"props": {},
							"group": 1,
							"target": {
								"instance": "CorpoTrainingCenter"
							},
							"cond": "ship == null && getDistance(getTarget()) < 1000"
						},
						{
							"text": "Pass the Cognitive and Physical Assessment.",
							"props": {
								"showCompleted": true
							},
							"cond": "isInInstance(Instance.CorpoTrainingCenter)",
							"group": 1
						},
						{
							"text": "Leave the ::target::.",
							"props": {},
							"group": 1,
							"cond": "hasEvent(Event.room4)",
							"target": {
								"instance": "CorpoTrainingCenter"
							}
						},
						{
							"text": "Do not enter the designers' offices.",
							"props": {
								"intercom": "Desk"
							},
							"group": 3,
							"cond": "hasEvent(Event.warning1)"
						},
						{
							"text": "DO NOT enter the designers' offices.",
							"props": {
								"intercom": "Desk2"
							},
							"group": 3,
							"cond": "hasEvent(Event.warning2)"
						}
					],
					"event": [
						{
							"id": "instructorTalk"
						},
						{
							"id": "entrance"
						},
						{
							"id": "desk1"
						},
						{
							"id": "desk2"
						},
						{
							"id": "warning1"
						},
						{
							"id": "warning2"
						},
						{
							"id": "room4"
						}
					],
					"intercom": [
						{
							"id": "End",
							"text": "Congrats, junior. You've earned yourself the title of *Novitiate*. Basically, it means you'll be a better asset to *The Company* if we give you more freedom.\nAccordingly, the *corpo interface* of your personal computer is now unlocked, allowing you to join or fund a *corpo*. I'd advise you to select your associates wisely, or fly solo if there's no one you trust.",
							"props": {
								"portrait": "CorpoTest_Ingrid"
							}
						},
						{
							"id": "Desk",
							"text": "OK, please refrain from visiting the test designers' offices.\nI know it's tempting, but it's not part of the assignment, and I don't think *The Company* likes it. They sent me a notification.",
							"props": {
								"portrait": "CorpoTest_Ingrid"
							}
						},
						{
							"id": "Desk2",
							"text": "I’ve just received a second notification from *The Company*. It seems you've ignored my warning and visited another designer's office, and now they're adding a *100 credit* fine to your debt.",
							"props": {
								"portrait": "CorpoTest_Ingrid"
							}
						}
					],
					"props": {
						"flags": 8,
						"screenshot": "ui/mission_pictures/Cognitivo-Physical Test.png"
					},
					"script": "function onCheck() {\n\tif(hasEvent(Event.room4)){\n\t\tif(!isInInstance(Instance.CorpoTrainingCenter)){\n\t\t\tcomplete();\n\t\t}\n\t}\n}\n\nfunction onEvent(v){\n\tif(v == Event.desk1){\n\t\tif(hasEvent(Event.warning1)){\n\t\t\tif(hasEvent(Event.desk2)){\n\t\t\t\tsetEvent(Event.warning2);\n\t\t\t}\n\t\t}\n\t\telse{\n\t\t\tsetEvent(Event.warning1);\n\t\t}\n\t}\n\tif(v == Event.desk2){\n\t\tif(hasEvent(Event.warning1)){\n\t\t\tif(hasEvent(Event.desk1)){\n\t\t\t\tsetEvent(Event.warning2);\n\t\t\t}\n\t\t}\n\t\telse{\n\t\t\tsetEvent(Event.warning1);\n\t\t}\n\t}\n\treturn true;\n}",
					"guid": "#Ydg-v6HI-YSS",
					"category": "MissionCorpo"
				},
				{
					"id": "CorpoCreateJoin",
					"requires": [
						{
							"mission": "CorpoTraining"
						}
					],
					"title": "Join a Corpo",
					"goal": "Create your own corpo or join an existing corpo.",
					"values": {
						"rewardXP": 50,
						"rewardAttr": "Social"
					},
					"steps": [
						{
							"text": "Create or join a corpo using the corpo menu [key.MenuCorpo]",
							"props": {},
							"group": 1
						}
					],
					"event": [],
					"intercom": [
						{
							"id": "End",
							"text": "Hello, traveling worker. I am contacting you on behalf of *The Republic*'s *Corporation Desk* to confirm that you are now legally bound to a *corpo*. This affiliation does not affect your ongoing arrangement with *The Company*.\nYou are invited to visit our branch office in *Helicon* and pick up your first *corpo request*. We have a variety of available *requests*, submitted to the *Corpo Administration Desk* by prestigious clients.\nIn anticipation of your visit, farewell.",
							"props": {
								"portrait": "CorpoContract_Comp_Threshold"
							}
						}
					],
					"props": {
						"screenshot": "ui/mission_pictures/JoinAcorpo.png"
					},
					"script": "function onCheck() {\n\tif( hasCorpo() )\n\t\tcomplete();\n}\n\nfunction onStart() {\n\tdiscoverItem(Item.Knowledge_Instances);\n}",
					"guid": "#Ydg-v6HN-MFr",
					"category": "MissionCorpo"
				},
				{
					"id": "CorpoFirstContract",
					"requires": [
						{
							"mission": "CorpoCreateJoin"
						}
					],
					"title": "First Corpo Request",
					"goal": "Complete your first Corpo request.",
					"values": {
						"targetObj": "Station_Terminus",
						"reward": 150
					},
					"steps": [
						{
							"text": "Go to ::target::.\n<small>Use your Galaxy Map with [key.MenuGalaxy] to help in your travels.</small>",
							"props": {}
						},
						{
							"text": "Go and talk to ::npc::.",
							"props": {
								"npc": "CorpoContract_Tuto"
							},
							"cond": "isInStation(getTarget(0))"
						},
						{
							"text": "Accept a request.",
							"props": {
								"showCompleted": true
							},
							"cond": "inDialogWith(Element.CorpoContract_Comp_Threshold)"
						},
						{
							"text": "Collect and deliver the requested materials to ::npc:: on ::target::\n<small>View request on corpo screen [key.MenuCorpo]</small>",
							"props": {
								"npc": "CorpoContract_Tuto",
								"showCompleted": true
							},
							"cond": "hasCorpoContract(true)"
						},
						{
							"text": "Open the Corpo Menu [key.MenuCorpo] to access the <lp>License List</lp>",
							"props": {
								"intercom": "TutoLP"
							},
							"cond": "hasEvent(Event.done)"
						},
						{
							"text": "Join or create a Corporation",
							"props": {},
							"cond": "!hasCorpo()"
						},
						{
							"text": "Navigate to the <lp>License List</lp>",
							"props": {},
							"group": 1,
							"cond": "hasEvent(Event.done) && inWindow(\"CorpoInfo\")"
						}
					],
					"event": [
						{
							"id": "done"
						}
					],
					"intercom": [
						{
							"id": "TutoLP",
							"text": "Congratulations. Now that you have fulfilled this first *corpo request*, you’ll find that your reward includes a handful of <lp>license points</lp>.\nThese <lp>license points</lp> can be spent by a *corpo*'s owners to benefit all of its members.\nOpen your *corpo interface* to discover all the advantages that <lp>license points</lp> can unlock.",
							"props": {
								"portrait": "CorpoContract_Comp_Threshold"
							}
						},
						{
							"id": "End",
							"text": "Excellent. Now that you’ve gone through these first steps, you are allowed to take *wholesale requests*.\nThese long-term commitments are more demanding, but they’re the best opportunities the *Corporation Desk* can offer.\nAs a *Company* affiliate, you can benefit from their guidance in automating your production to help reach the high efficiency levels that *wholesale requests* demand.",
							"props": {
								"portrait": "CorpoContract_Comp_Threshold"
							}
						}
					],
					"props": {
						"screenshot": "ui/mission_pictures/CorpoFirstContract.png"
					},
					"script": "function onContractCompleted(c) {\n\tsetEvent(Event.done);\n\tcloseWindow(true);\n}\nfunction onCheck() {\n\tif( hasEvent(Event.done) ) {\n\t\tif( inWindow(\"CorpoInfo\") ) highlightButton(Icon.CorpoPageLicenses,1);\n\t\tif( inWindow(\"CorpoPermits\") ) complete();\n\t}\n}",
					"guid": "#Ydg-v6HS-SVg",
					"category": "MissionCorpo"
				},
				{
					"id": "CorpoBigContract",
					"requires": [
						{
							"mission": "CorpoFirstContract"
						}
					],
					"title": "Wholesale Request",
					"goal": "Accept a level 1+ wholesale request.",
					"values": {
						"targetObj": "Station_Terminus",
						"vars": {
							"res": "IronIngot"
						},
						"reward": 100
					},
					"steps": [
						{
							"text": "Go to ::target::. Use your Galaxy Map with [key.MenuGalaxy] to help in your travels.",
							"props": {}
						},
						{
							"text": "Go and talk to ::npc::.",
							"props": {
								"npc": "CorpoContract_Tuto"
							},
							"cond": "isInStation(getTarget(0))"
						},
						{
							"text": "Accept a level 1 request for [::vars.res::] or another.",
							"props": {},
							"cond": "inDialogWith(Element.CorpoContract_Tuto)"
						},
						{
							"text": "Join or create a Corporation",
							"props": {},
							"cond": "!hasCorpo()"
						}
					],
					"event": [],
					"intercom": [
						{
							"id": "End",
							"text": "This is a promising step. By taking on a *wholesale request*, you are entering the highest playing field.\nIn order to meet that significant demand, you could invite more people to join your *corpo*. At some point, however, you should also consider automating your production line.\nSince you’re affiliated with *The Company*, I suggest that you meet with *Ida Lin* and ask her about *automated base* construction.",
							"props": {
								"portrait": "CorpoContract_Comp_Threshold"
							}
						}
					],
					"props": {
						"screenshot": "ui/mission_pictures/CorpoFirstContract.png"
					},
					"script": "function onStart() {\n\tvars.res = random(2) == 0 ? \"IronIngot\" : \"CopperIngot\";\n}\n\nfunction onCheck() {\n\tif( hasCorpoContract() ) {\n\t\tcloseWindow();\n\t\tcomplete();\n\t}\n}",
					"guid": "#Ydg-v6HX-8RG",
					"category": "MissionCorpo"
				},
				{
					"id": "BaseIntro",
					"requires": [],
					"title": "A new contact...",
					"goal": "Meet with ::npc::",
					"values": {
						"targetObj": "Station_Terminus"
					},
					"steps": [
						{
							"text": "Find and talk to ::npc:: on ::target::",
							"props": {
								"npc": "Terminus_CompanyRep"
							}
						}
					],
					"event": [],
					"intercom": [],
					"props": {
						"flags": 36,
						"screenshot": "ui/mission_pictures/BaseIntro.png"
					},
					"script": "function onCheck() {\n\tif( hasMission(Mission.FirstBase) || hasCompletedMission(Mission.FirstBase) ) fail();\n}\nfunction onStart() {\n\tonCheck();\n}\n",
					"guid": "#Ydg-v6Hb-8f&",
					"category": "MissionBase"
				},
				{
					"id": "FirstBase",
					"requires": [
						{
							"mission": "CorpoBigContract"
						}
					],
					"title": "Space Base 101",
					"goal": "Deploy a planetary base to claim a deposit.",
					"values": {
						"item": "P_ConstructionTool",
						"permit": "P_FirstBase",
						"vars": {
							"dep": ""
						},
						"reward": 200
					},
					"steps": [
						{
							"text": "Unlock the ::permit:: permit.",
							"cond": "!canCraft(mission.item)",
							"props": {},
							"group": 1
						},
						{
							"text": "Gather the following in your inventory:\n::inventory.Concrete.14::\n::inventory.Plate1.1::\n::inventory.Motor.1::\n::inventory.Coil.2::\n::inventory.Wire.4::",
							"props": {},
							"cond": "canCraft(mission.item)",
							"group": 1
						},
						{
							"text": "Craft a ::item::.",
							"cond": "canCraft(mission.item) && !isEquipped(mission.item)",
							"props": {},
							"group": 0
						},
						{
							"text": "Press [key.MenuCharacter] to open the character screen, then equip your ::item::.",
							"cond": "getItemCount(mission.item)>=1 && canCraft(mission.item) && !isEquipped(mission.item)",
							"props": {},
							"group": 0
						},
						{
							"text": "Get a [ControlBaseKit] in your inventory.",
							"props": {},
							"group": 2,
							"cond": "hasPermit(mission.permit) && getItemCount(Item.ControlBaseKit)==0"
						},
						{
							"text": "Talk to ::npc:: in ::target::",
							"props": {
								"npc": "Terminus_CompanyRep"
							},
							"group": 2,
							"target": {
								"object": "Station_Terminus"
							},
							"cond": "!hasEvent(Event.GotFreeKit)"
						},
						{
							"text": "Build a [B_ControlBase] near an [::vars.dep::] to claim it.\n<small>You can visit the *Mining Bureau* of any sector to locate an available deposit.</small>",
							"cond": "getItemCount(Item.ControlBaseKit)>0 && getItemCount(Item.Plate1)>=1 && getItemCount(Item.Motor)>=1 && getItemCount(Item.Coil)>=2\n&& getItemCount(Item.Wire)>=4 && getItemCount(Item.Concrete) >= 14",
							"props": {},
							"group": 1
						},
						{
							"text": "Approach the detected [::vars.dep::]",
							"props": {},
							"group": 1,
							"cond": "getItemCount(Item.ControlBaseKit)>0 && (radarHasDetectedResource(toRes(vars.dep)) || radarHasResourceAtRange(toRes(vars.dep)))"
						},
						{
							"text": "Approach the detected [::vars.dep::] and scan it",
							"props": {},
							"group": 1,
							"cond": "getItemCount(Item.ControlBaseKit)>0 && (radarHasDetectedResource(toRes(vars.dep)) || radarHasResourceAtRange(toRes(vars.dep))) && !isResourceScanned(toRes(vars.dep))"
						},
						{
							"text": "Press [key.Descend] over a flat surface to descend until you land close to the deposit",
							"props": {},
							"group": 1,
							"cond": "getItemCount(Item.ControlBaseKit)>0 && radarHasResourceAtRange(toRes(vars.dep)) && isResourceScanned(toRes(vars.dep))"
						},
						{
							"text": "No [::vars.dep::] was found nearby. Take off and find another place.",
							"props": {},
							"group": 1,
							"cond": "getItemCount(Item.ControlBaseKit)>0 && isEquipped(mission.item) && isOnPlanet()"
						},
						{
							"text": "Deploy your base using [key.Deploy]",
							"cond": "getItemCount(Item.ControlBaseKit)>0 && isEquipped(mission.item) && isOnPlanet() && locateNearestResource(toRes(vars.dep),150) != null",
							"props": {},
							"group": 1
						}
					],
					"event": [
						{
							"id": "GotFreeKit"
						}
					],
					"intercom": [
						{
							"id": "End",
							"text": "Congratulations on deploying your first [B_ControlBase]!\nThis base will provide you with some private storage and limited power input, but this is just the beginning.\nIn order to automate resource extraction, you’ll need to deploy an [B_Extractor] and a [B_Smelter].",
							"props": {
								"portrait": "Terminus_CompanyRep"
							}
						}
					],
					"props": {
						"screenshot": "ui/mission_pictures/FirtsBase.png"
					},
					"script": "function onStart() {\n\tvar d = resolveCorpoContractDeposit();\n\tif( d == null ) d = Resource.IronDeposit;\n\tvars.dep = \"\"+d;\n\tif( getBases(true).length > 0 ) complete();\n}\n\nfunction onDeploy(_) {\n\tcomplete();\n}",
					"guid": "#Ydg-v6Hf-2yI",
					"category": "MissionBase"
				},
				{
					"id": "BaseSmelter",
					"requires": [
						{
							"mission": "FirstBase"
						}
					],
					"title": "Space Base 102",
					"goal": "Build and activate an extractor and a smelter.",
					"values": {
						"rewardAttr": "Technology",
						"rewardXP": 10,
						"reward": 200
					},
					"steps": [
						{
							"text": "Deploy an [B_Extractor] on the deposit.",
							"props": {
								"end": "Extractor"
							},
							"group": 0
						},
						{
							"text": "Connect the [B_Extractor] to the [B_ControlBase] Network using a [B_ElectricPillar].",
							"cond": "hasEvent(Event.Extractor)",
							"props": {
								"end": "E_Connected"
							},
							"group": 0
						},
						{
							"text": "Deploy a [B_Smelter].",
							"props": {
								"end": "Smelter"
							},
							"group": 1
						},
						{
							"text": "Connect the [B_Smelter] to the [B_ControlBase] Network using a [B_ElectricPillar].",
							"props": {
								"end": "S_Connected"
							},
							"group": 1,
							"cond": "hasEvent(Event.Smelter)"
						},
						{
							"text": "Select a craft recipe on the [B_Smelter], take some output from the [B_Extractor] and add it to the [B_Smelter] to activate it.",
							"props": {},
							"cond": "hasEvent(Event.E_Connected) && hasEvent(Event.S_Connected)",
							"group": 0
						},
						{
							"text": "Aim the top of a [B_ElectricPillar] and press ::key.Action:: to connect it to a building.",
							"props": {
								"subGoal": true
							},
							"group": 2,
							"cond": "hasEvent(Event.Pylon) && (hasEvent(Event.Smelter)||hasEvent(Event.Extractor)) && (!hasEvent(Event.E_Connected)||!hasEvent(Event.S_Connected))"
						}
					],
					"event": [
						{
							"id": "Extractor"
						},
						{
							"id": "Smelter"
						},
						{
							"id": "E_Connected"
						},
						{
							"id": "S_Connected"
						},
						{
							"id": "Pylon"
						}
					],
					"intercom": [
						{
							"id": "End",
							"text": "Now you’re off to a very promising start. Although automated smelting can be slow, it is continuous and does not require your presence. It will work for you while you are away to effortlessly provide a steady flow of ingots.\nBy expanding this procedure to the whole production chain, you will move beyond the hassle of strictly manual labor. Extractors will gather ore for you. Smelters will refine them. Factories will turn the resulting ingots into complex objects. \nBefore you know it, there will be nothing standing between you and financial success!",
							"props": {
								"portrait": "Terminus_CompanyRep"
							}
						}
					],
					"props": {
						"screenshot": "ui/mission_pictures/BaseSmelter.png"
					},
					"script": "function onCheck() {\n\tvar base = getLocalBase();\n\tif( base != null ) {\n\t\tif( base.hasBuilding(Item.B_Extractor) ) {\n\t\t\ttriggerEvent(Event.Extractor);\n\t\t\tif( base.hasPoweredBuilding(Item.B_Extractor) )\n\t\t\t\ttriggerEvent(Event.E_Connected);\n\t\t}\n\t\tif( base.hasBuilding(Item.B_Smelter) ) {\n\t\t\ttriggerEvent(Event.Smelter);\n\t\t\tif( base.hasPoweredBuilding(Item.B_Smelter) )\n\t\t\t\ttriggerEvent(Event.S_Connected);\n\t\t}\n\t\tif(base.hasBuilding(Item.B_ElectricPillar)){\n\t\t\ttriggerEvent(Event.Pylon);\n\t\t}\n\t\tif( hasEvent(Event.E_Connected) && hasEvent(Event.S_Connected) && base.hasActiveBuilding(Item.B_Smelter) ) {\n\t\t\tcloseWindow();\n\t\t\tcomplete();\n\t\t}\n\t}\n}\n",
					"guid": "#Ydg-v6Hg-#kz",
					"category": "MissionBase"
				},
				{
					"id": "BaseXP",
					"requires": [
						{
							"mission": "BaseSmelter"
						}
					],
					"title": "Technology LV1",
					"goal": "Increase your *Technology* level.",
					"values": {
						"reward": 300
					},
					"steps": [
						{
							"text": "Access the [B_ControlBase] terminal",
							"props": {
								"end": "claimed"
							},
							"cond": ""
						},
						{
							"text": "Collect some *Technology XP* when available",
							"props": {
								"intercom": "XPTuto",
								"end": "claimed"
							},
							"cond": "inDialogWith(Element.ControlBase_BaseSettingsComputer) || inWindow(\"TechnologyXp\")"
						},
						{
							"text": "Reach *Technology* Level *1*",
							"props": {
								"showCompleted": true
							},
							"cond": "hasEvent(Event.claimed)"
						}
					],
					"event": [
						{
							"id": "claimed"
						}
					],
					"intercom": [
						{
							"id": "XPTuto",
							"text": "Crafting or smelting will produce *Technology XP* within each space base. You can collect this XP to increase your Technology level.",
							"props": {
								"portrait": "Terminus_CompanyRep"
							}
						}
					],
					"props": {
						"screenshot": "ui/mission_pictures/Technology2.png"
					},
					"script": "function onXP(a,v) {\n\tif( a == Attribute.Technology ) {\n\t\tif( isEventOf(getLocalBase()) )\n\t\t\tsetEvent(Event.claimed);\n\t\tif( hasEvent(Event.claimed) ) {\n\t\t\tsetProgress(getPlayerLevelXP(Attribute.Technology));\n\t\t\tif( getPlayerLevel(Attribute.Technology) >= 1 )\n\t\t\t\tcomplete();\n\t\t}\n\t}\n}",
					"guid": "#Ydg-v6Hl-bIN",
					"category": "MissionBase"
				},
				{
					"id": "BaseAutomate",
					"guid": "#bSL-dMkS-ubR",
					"requires": [
						{
							"mission": "BaseSmelter"
						}
					],
					"title": "Space Base 103",
					"goal": "Automatize your base production with ::item::",
					"values": {
						"item": "Drone0",
						"permit": "P_BaseFactory",
						"item2": "B_Factory1",
						"reward": 300
					},
					"steps": [
						{
							"text": "Connect your [B_Smelter] output to your [B_Warehouse] using a ::item::",
							"props": {}
						},
						{
							"text": "Deploy a [B_Warehouse]",
							"props": {},
							"cond": "!hasEvent(Event.haswarehouse)"
						},
						{
							"text": "Create a drone route between your [B_Extractor] output and [B_Smelter]",
							"props": {},
							"cond": "!hasEvent(Event.connected)"
						},
						{
							"text": "Craft a ::item::",
							"props": {},
							"cond": "!hasItem(mission.item) && !hasEvent(Event.connected)"
						},
						{
							"text": "Unlock the permit ::permit::",
							"props": {},
							"cond": "!hasPermit(mission.permit)"
						},
						{
							"text": "Increase your *Science* Level to *2*\n<small>The science level can be improved at the *Laboratory*</small>",
							"props": {},
							"cond": "getPlayerLevel(Attribute.Science) < 2"
						},
						{
							"text": "Increase your *Science* Level to *2*\n<small>Some other contracts will help you doing that</small>",
							"props": {},
							"cond": "getPlayerLevel(Attribute.Science) < 2 && !hasCompletedMission(Mission.FirstScience)"
						}
					],
					"event": [
						{
							"id": "connected"
						},
						{
							"id": "haswarehouse"
						}
					],
					"intercom": [
						{
							"id": "End",
							"text": "Congratulations, you now have a fully automated production in your space base. Well, you will still have to carry the produced resources by yourself for now. This is only the beginning...",
							"props": {
								"portrait": "Terminus_CompanyRep"
							}
						}
					],
					"props": {
						"screenshot": "ui/mission_pictures/Automatise.png"
					},
					"script": "function onSpecialAction(act) {\n\tif( act == SpecialAction.AddRoute ) {\n\t\tvar base = getLocalBase();\n\t\tif( base.hasConnectedBuilding(Item.B_Extractor,Item.B_Smelter) ) {\n\t\t\tsetEvent(Event.connected);\n\t\t\tif( base.hasBuilding(Item.B_Warehouse) ) setEvent(Event.haswarehouse);\n\t\t}\n\t\tif( base.hasConnectedBuilding(Item.B_Smelter,Item.B_Warehouse) )\n\t\t\tcomplete();\n\t}\n}\nfunction onDeploy(b) {\n\tif( b == Item.B_Warehouse )\n\t\tsetEvent(Event.haswarehouse);\n}",
					"category": "MissionBase"
				},
				{
					"id": "BaseLandingPad",
					"guid": "#bTg-ZdLy-DIg",
					"title": "Space Base 104",
					"goal": "Deploy and land on a ::item::",
					"values": {
						"item": "B_LandingPad",
						"reward": 100
					},
					"steps": [
						{
							"text": "Land your ship on the ::item::",
							"props": {}
						},
						{
							"text": "Deploy a ::item:: into your space base",
							"props": {},
							"cond": "!hasEvent(Event.hasPad)"
						}
					],
					"event": [
						{
							"id": "hasPad"
						}
					],
					"intercom": [],
					"requires": [
						{
							"mission": "BaseAutomate"
						}
					],
					"props": {
						"screenshot": "ui/mission_pictures/CreateLandingPad.png"
					},
					"script": "function onStart() {\n\tif( getLocalBase()?.hasBuilding(mission.item) )\n\t\tsetEvent(Event.hasPad);\n}\n\nfunction onDeploy(b) {\n\tonStart();\n}\n\nfunction onRelocate() {\n\tvar base = getLocalBase();\n\tvar ship = getShip();\n\tif( base != null && ship != null ) {\n\t\tfor( b in base.getBuildings(mission.item) )\n\t\t\tif( ship.isDocked(b) ) {\n\t\t\t\tcomplete();\n\t\t\t\treturn;\n\t\t\t}\n\t}\n}",
					"category": "MissionBase"
				},
				{
					"id": "TechnologyLV2",
					"requires": [
						{
							"mission": "BaseLandingPad"
						},
						{
							"mission": "BaseXP"
						}
					],
					"title": "TECH#01: Technology Novice",
					"goal": "Develop your base and reach *Technology* level *::qty::*",
					"values": {
						"count": 2,
						"reward": 300
					},
					"steps": [
						{
							"text": "Gain XP by deploying new buildings",
							"props": {},
							"group": 1
						},
						{
							"text": "Deploy a [B_Factory1]",
							"props": {
								"subGoal": true
							},
							"group": 2,
							"cond": "!hasEvent(Event.BuiltFactory)"
						},
						{
							"text": "Deploy a [B_SmelterSA]",
							"props": {
								"subGoal": true
							},
							"group": 3,
							"cond": "!hasEvent(Event.BuiltSmelter)"
						},
						{
							"text": "Deploy a [B_SolarPanel]",
							"props": {
								"subGoal": true
							},
							"group": 4,
							"cond": "!hasEvent(Event.BuiltSolar)"
						},
						{
							"text": "Get Tech XP points from your [B_ControlBase] computer.",
							"props": {},
							"group": 0
						}
					],
					"event": [
						{
							"id": "BuiltFactory"
						},
						{
							"id": "BuiltSolar"
						},
						{
							"id": "BuiltSmelter"
						}
					],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/Technology2.png"
					},
					"script": "function onXP(a,_) {\n\tif( a == Attribute.Technology && getPlayerLevel(a) >= mission.count )\n\t\tcomplete();\n}\nfunction onCheck() {\n\tvar b = getLocalBase();\n\tif( b != null ) {\n\t\tif( b.hasBuilding(Item.B_Factory1) ) triggerEvent(Event.BuiltFactory);\n\t\tif( b.hasBuilding(Item.B_SmelterSA) ) triggerEvent(Event.BuiltSmelter);\n\t\tif( b.hasBuilding(Item.B_SolarPanel) ) triggerEvent(Event.BuiltSolar);\n\t}\n}",
					"guid": "#Ydg-v6Iw-4Pc",
					"category": "MissionBase"
				},
				{
					"id": "Dismantle",
					"guid": "#cU#-93R&-fV#",
					"title": "De-Synthesis",
					"goal": "Complete de-synthesis apprentice level.",
					"values": {
						"item": "P_DismentlingTool",
						"reward": 100
					},
					"steps": [
						{
							"text": "Build and equip a ::item::",
							"props": {}
						},
						{
							"text": "Dismantle a useless base buillding.\n<small>Abandonned bases can be located using the *Mining Bureau*, or you can dismantle one of your buildings</small>",
							"props": {},
							"cond": "isEquipped(mission.item)"
						}
					],
					"event": [],
					"intercom": [],
					"requires": [
						{
							"mission": "TechnologyLV2"
						}
					],
					"props": {
						"screenshot": "ui/mission_pictures/Dismantle.png"
					},
					"script": "function onSpecialAction(act) {\n\tif( act == SpecialAction.DismantleBase || act == SpecialAction.DismantleBuilding )\n\t\tcomplete();\n}",
					"category": "MissionBase"
				},
				{
					"id": "BaseLiquids",
					"guid": "#bUd-6FCa-Xce",
					"title": "Interplanetary Logistics [1/2]",
					"goal": "Start ::item:: production in your  [B_Chemical]",
					"values": {
						"permit": "P_Plumbing",
						"item": "CarbonicFuel",
						"item2": "GraphiteCrystal",
						"resource": "WaterGeyser",
						"reward": 1000
					},
					"steps": [
						{
							"text": "Deploy a [B_Chemical] in your base and produce ::item::",
							"props": {},
							"cond": ""
						},
						{
							"text": "Deploy a [B_Chemical] in your base and produce ::item::\n<small>Changing [Water_Brine] into [Water] will require another [B_Cistern]</small>",
							"props": {},
							"cond": "getLocalBase()?.hasLiquid(Item.Water_Brine)"
						},
						{
							"text": "Fill the [B_Cistern] with [Water]\n<small>In order to fill your cistern, your ship need to be landed on a Landing Pad</small>",
							"props": {},
							"cond": "!getLocalBase()?.hasLiquid(Item.Water) && !getLocalBase()?.hasLiquid(Item.Water_Brine)"
						},
						{
							"text": "Deploy a [B_Cistern] in your base",
							"props": {},
							"cond": "!getLocalBase()?.hasBuilding(Item.B_Cistern)"
						},
						{
							"text": "Collect [Water]  on a planet\n<small>Water can be collected over geysers or by activating your pump while your ship is submerged</small>",
							"props": {},
							"cond": "!getShip()?.hasLiquid(Item.Water) && !getShip()?.hasLiquid(Item.Water_Brine) && !hasEvent(Event.filled)"
						},
						{
							"text": "Craft and install [LiquidStorage1] and [FluidPumpingTool1] in your ship.",
							"props": {},
							"cond": "!(getShip()?.hasComponent(Item.LiquidStorage1) && getShip()?.hasComponent(Item.FluidPumpingTool1))"
						},
						{
							"text": "Unlock *::permit::* permit",
							"props": {},
							"cond": "!hasPermit(mission.permit)"
						},
						{
							"text": "Study ::item2:: at *Laboratory*",
							"props": {},
							"cond": "getScienceLevel(mission.item2) < 1"
						}
					],
					"event": [
						{
							"id": "filled"
						}
					],
					"intercom": [
						{
							"id": "Start",
							"text": "It is now time for you to work on the next important step of your space base. *Interplanetary Logistists* will allow you to connect your base to stations and future other bases. But before we get there, you will have to master some new things...",
							"props": {
								"portrait": "Terminus_CompanyRep"
							}
						}
					],
					"requires": [
						{
							"mission": "BaseLandingPad"
						}
					],
					"props": {
						"screenshot": "ui/mission_pictures/BaseLiquids.png"
					},
					"script": "function onGather(it,_) {\n\tif( it == mission.item ) complete();\n}\nfunction onCheck() {\n\tif( !hasEvent(Event.filled) && (getLocalBase()?.hasLiquid(Item.Water) || getLocalBase()?.hasLiquid(Item.Water_Brine)) )\n\t\ttriggerEvent(Event.filled);\n\tvar b = getLocalBase();\n\tif( b?.hasCraftingBuilding(mission.item) ) complete();\n}",
					"category": "MissionBase"
				},
				{
					"id": "DismantleWrecks",
					"guid": "#cVD-lsky-nSR",
					"title": "Wrecks collection",
					"goal": "Locate and dismantle shipwrecks.",
					"values": {
						"count": 3,
						"item": "P_MovingTool",
						"reward": 100
					},
					"steps": [
						{
							"text": "Reach Technology LV3",
							"props": {}
						},
						{
							"text": "Craft and equip ::item::",
							"props": {},
							"cond": "getPlayerLevel(Attribute.Technology) >= 3"
						},
						{
							"text": "Locate and dismantle ::count:: shipwrecks.",
							"props": {},
							"cond": "isEquipped(mission.item)"
						}
					],
					"event": [],
					"intercom": [],
					"requires": [
						{
							"mission": "BaseLiquids"
						}
					],
					"props": {},
					"script": "function onSpecialAction(act) {\n\tif( act == SpecialAction.DismantleWreck ) {\n\t\tprogress(1);\n\t\tif( isProgressFull() ) complete();\n\t}\n}",
					"category": "MissionBase"
				},
				{
					"id": "BaseShuttle",
					"guid": "#bUd-7BCf-6mh",
					"title": "Interplanetary Logistics [2/2]",
					"goal": "Connect your base logistics with the nearest <img src=\"item/SpaceStation0\"/>*SpaceStation*",
					"values": {
						"item": "B_ShuttlePad",
						"item2": "Shuttle0"
					},
					"steps": [
						{
							"text": "Reach Technology LV4",
							"props": {}
						},
						{
							"text": "Deploy a ::item:: into your base",
							"props": {},
							"cond": "getPlayerLevel(Attribute.Technology) >= 4"
						},
						{
							"text": "Build a ::item2:: and assign it to your ::item::",
							"props": {},
							"cond": "hasEvent(Event.Built)"
						},
						{
							"text": "Assign a route to your ::item2::\n<small>This will allow you to transfer goods between your base and a station or another base</small>",
							"props": {},
							"cond": "getLocalBase()?.hasShuttle(false)"
						}
					],
					"event": [
						{
							"id": "Built"
						}
					],
					"intercom": [],
					"requires": [
						{
							"mission": "BaseLiquids"
						}
					],
					"props": {
						"screenshot": "ui/mission_pictures/BaseShuttle.png"
					},
					"script": "function onCheck() {\n\tif( getLocalBase()?.hasBuilding(mission.item) ) triggerEvent(Event.Built);\n\tif( getLocalBase()?.hasShuttle(true) ) complete();\n}",
					"category": "MissionBase"
				},
				{
					"id": "BaseContractLv2",
					"requires": [
						{
							"mission": "BaseSmelter"
						},
						{
							"mission": "CorpoBigContract"
						}
					],
					"title": "Corpo Level 2",
					"goal": "Complete a Lv.2 Corpo request.",
					"values": {
						"vars": {
							"corpo": false,
							"count": 0
						},
						"reward": 500
					},
					"steps": [
						{
							"text": "Complete one Lv.2+ corpo request using your automated base output.\n<small>The request can be found on the corpo page [key.MenuCorpo]</small>",
							"props": {}
						},
						{
							"text": "Use your automated base to help the Corpo complete the request.\n<small>The requests can be found on the corpo page [key.MenuCorpo]</small>",
							"props": {},
							"cond": "!hasCorpoSolo()"
						},
						{
							"text": "Accept a Lv.2+ corpo request",
							"props": {},
							"cond": "!hasCorpoContract()"
						},
						{
							"text": "Join or create a corpo",
							"props": {},
							"cond": "!hasCorpo()"
						}
					],
					"event": [
						{
							"id": "corpoChange"
						}
					],
					"intercom": [],
					"props": {
						"screenshot": "ui/mission_pictures/CorpoFirstContract.png"
					},
					"script": "function onStart() {\n\tif( hasCorpo() ) {\n\t\tif( !vars.corpo ) {\n\t\t\tvars.corpo = true;\n\t\t\tvars.count = getCorpoCompletedContracts();\n\t\t}\n\t} else\n\t\tvars.corpo = false;\n}\n\nfunction onEvent(_) {\n\tonStart();\n\treturn false;\n}\n\nfunction onCheck() {\n\tif( vars.corpo != hasCorpo() )\n\t\ttriggerEvent(Event.corpoChange);\n\telse if( vars.corpo && getCorpoCompletedContracts() > vars.count )\n\t\tcomplete();\n}",
					"guid": "#Ydg-v6Ho-6ou",
					"category": "MissionBase"
				},
				{
					"id": "CorpoContractLevel",
					"guid": "#Yig-dw&o-xFz",
